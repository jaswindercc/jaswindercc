---
import { getCollection } from 'astro:content';
import config from '../data/config.json';
import '../styles/global.css';
import MainLayout from '../components/MainLayout.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const displayedPosts = sortedPosts.slice(0, 6);

function getCategory(id: string): string {
	const map: Record<string, string> = {
		'agentic-ai-compliance': 'AI',
		'claude-mythos-5': 'AI',
		'edge-computing-2026': 'Cloud',
		'enterprise-devops-modernization': 'DevOps',
		'finops-best-practices': 'FinOps',
		'metadata-saturation': 'Analytics',
		'retail-banking-api-architecture': 'Architecture',
		'securing-openclaw': 'Security',
		'zero-trust-cloud-security': 'Security',
	};
	const slug = id.replace(/\.mdx?$/, '');
	return map[slug] || 'Tech';
}

function getCategoryStyle(category: string): { bg: string; text: string; border: string; dot: string } {
	const styles: Record<string, { bg: string; text: string; border: string; dot: string }> = {
		'AI': { bg: 'bg-violet-50', text: 'text-violet-700', border: 'border-violet-200', dot: 'bg-violet-500' },
		'Cloud': { bg: 'bg-sky-50', text: 'text-sky-700', border: 'border-sky-200', dot: 'bg-sky-500' },
		'DevOps': { bg: 'bg-emerald-50', text: 'text-emerald-700', border: 'border-emerald-200', dot: 'bg-emerald-500' },
		'FinOps': { bg: 'bg-amber-50', text: 'text-amber-700', border: 'border-amber-200', dot: 'bg-amber-500' },
		'Analytics': { bg: 'bg-rose-50', text: 'text-rose-700', border: 'border-rose-200', dot: 'bg-rose-500' },
		'Architecture': { bg: 'bg-indigo-50', text: 'text-indigo-700', border: 'border-indigo-200', dot: 'bg-indigo-500' },
		'Security': { bg: 'bg-red-50', text: 'text-red-700', border: 'border-red-200', dot: 'bg-red-500' },
	};
	return styles[category] || { bg: 'bg-slate-50', text: 'text-slate-700', border: 'border-slate-200', dot: 'bg-slate-500' };
}

const pageTitle = 'Cloud Architecture, AI Expert & Technical Leadership | Jaswinder Singh';
const pageDescription = 'Jaswinder Singh helps companies modernize cloud architecture, AI implementations, and technical leadership with secure AI and DevOps solutions.';
---

<MainLayout title={pageTitle} description={pageDescription} keywords={['Cloud Architecture', 'AI Expert', 'Technical Leadership', 'AI', 'Cloud', 'DevOps']} canonical="/">
	<main class="max-w-6xl mx-auto py-16 px-6">
		<div class="flex flex-col lg:flex-row lg:gap-12">
			<!-- Left Column: Profile, Connect, What I Do -->
			<div class="lg:w-[420px] lg:shrink-0">
				<!-- Header -->
				<header class="mb-14 animate-section">
					<div class="flex items-center gap-3 mb-4">
						<div class="w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-violet-600 flex items-center justify-center text-white font-bold text-lg">JS</div>
						<div>
							<h1 class="text-3xl font-bold tracking-tight text-slate-950">{config.name}</h1>
							<p class="text-sm font-medium text-blue-600">{config.title}</p>
						</div>
					</div>
					<p class="text-base leading-relaxed text-slate-600">{config.bio}</p>
				</header>

				<!-- Connect -->
				<section class="mb-14 animate-section">
					<h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Contact</h2>
					<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
						<div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
							<span class="text-sm font-medium text-slate-500">Email</span>
							<button
								id="email-btn"
								type="button"
								class="text-sm text-blue-600 hover:text-blue-800 font-medium transition-colors cursor-pointer"
								data-a="hello"
								data-b="jaswinder"
								data-c="cc"
							>
								Click to reveal
							</button>
						</div>
						{config.socials.map((social) => (
							<div class="flex items-center justify-between px-4 py-3 border-b border-slate-100 last:border-b-0">
								<span class="text-sm font-medium text-slate-500">{social.platform}</span>
								<a
									href={social.url}
									target="_blank"
									rel="noopener noreferrer"
									class="text-sm text-blue-600 hover:text-blue-800 transition-colors"
								>
									{social.url.replace(/^https?:\/\//, '')}
								</a>
							</div>
						))}
					</div>
				</section>

				<!-- What I Do -->
				<section class="mb-14 animate-section">
					<h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-5">Cloud Architecture & Technical Leadership</h2>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
						<div class="card-hover bg-white rounded-xl border border-slate-200 shadow-sm p-5 border-l-4 border-l-blue-500">
							<div class="flex items-center gap-2 mb-2">
								<span class="text-lg">⚡</span>
								<h3 class="text-base font-bold text-slate-950">Scale Infrastructure</h3>
							</div>
							<p class="text-sm text-slate-500 leading-relaxed">Architecting systems that handle high-volume, mission-critical traffic without failing.</p>
						</div>
						<div class="card-hover bg-white rounded-xl border border-slate-200 shadow-sm p-5 border-l-4 border-l-violet-500">
							<div class="flex items-center gap-2 mb-2">
								<span class="text-lg">🤖</span>
								<h3 class="text-base font-bold text-slate-950">Deploy Agentic AI</h3>
							</div>
							<p class="text-sm text-slate-500 leading-relaxed">Moving beyond basic prompts to build autonomous AI agents that solve real business problems.</p>
						</div>
						<div class="card-hover bg-white rounded-xl border border-slate-200 shadow-sm p-5 border-l-4 border-l-amber-500">
							<div class="flex items-center gap-2 mb-2">
								<span class="text-lg">🗺️</span>
								<h3 class="text-base font-bold text-slate-950">Technical Leadership</h3>
							</div>
							<p class="text-sm text-slate-500 leading-relaxed">Translating executive goals into robust technical roadmaps that actually deliver ROI.</p>
						</div>
						<div class="card-hover bg-white rounded-xl border border-slate-200 shadow-sm p-5 border-l-4 border-l-emerald-500">
							<div class="flex items-center gap-2 mb-2">
								<span class="text-lg">☁️</span>
								<h3 class="text-base font-bold text-slate-950">Cloud Modernization</h3>
							</div>
							<p class="text-sm text-slate-500 leading-relaxed">Leading large-scale migrations and establishing Cloud Centers of Excellence (CCoE) for governed growth.</p>
						</div>
					</div>
				</section>
			</div>

			<!-- Right Column: Blog Posts -->
			<div class="flex-1 min-w-0">
				{displayedPosts.length > 0 && (
					<section class="mb-14 animate-section lg:sticky lg:top-8">
						<h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-5">Blog Posts</h2>
						<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden divide-y divide-slate-100">
							{displayedPosts.map((post) => {
								const cat = getCategory(post.id);
								const style = getCategoryStyle(cat);
								return (
									<a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="block post-row px-5 py-4 no-underline">
										<div class="flex items-start justify-between gap-3">
											<div class="flex-1 min-w-0">
												<h3 class="text-base font-semibold text-slate-900 mb-1 group-hover:text-blue-600">{post.data.title}</h3>
												<p class="text-sm text-slate-500 line-clamp-2">{post.data.description}</p>
											</div>
											<span class={`shrink-0 inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full ${style.bg} ${style.text}`}>
												<span class={`w-1.5 h-1.5 rounded-full ${style.dot}`}></span>
												{cat}
											</span>
										</div>
									</a>
								);
							})}
						</div>
						<div class="mt-4 text-center">
							<a href="/blog/" class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
								View all posts
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
								</svg>
							</a>
						</div>
					</section>
				)}
			</div>
		</div>
	</main>
</MainLayout>
<script>
document.getElementById('email-btn')?.addEventListener('click', function () {
const btn = this as HTMLButtonElement;
const email = `${btn.dataset.a}@${btn.dataset.b}.${btn.dataset.c}`;
btn.textContent = email;
btn.classList.remove('hover:text-blue-800');
btn.addEventListener('click', function copyHandler() {
navigator.clipboard.writeText(email).then(() => {
btn.textContent = 'Copied!';
setTimeout(() => { btn.textContent = email; }, 2000);
});
});
}, { once: true });
</script>
