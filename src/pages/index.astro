---
import { getCollection } from 'astro:content';
import config from '../data/config.json';
import '../styles/global.css';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const jsonLdPerson = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: config.name,
  jobTitle: config.title,
  description: config.bio,
  sameAs: config.socials.map(social => social.url),
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={config.bio} />
		<title>{config.name} | {config.title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLdPerson)}></script>
	</head>
	<body class="bg-white text-slate-900 font-sans">
		<main class="max-w-2xl mx-auto py-16 px-6">
			<header class="mb-16 border-b border-slate-200 pb-12">
				<h1 class="text-5xl font-bold tracking-tight mb-3 text-slate-950">{config.name}</h1>
				<p class="text-xl font-light text-slate-600 mb-4">{config.title}</p>
				<p class="text-base leading-relaxed text-slate-700">{config.bio}</p>
			</header>

			{recentPosts.length > 0 && (
				<section class="mb-16">
					<h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-6">Latest Insights</h2>
					<div class="space-y-6">
						{recentPosts.map((post) => (
							<article class="group border-l-2 border-slate-300 hover:border-slate-600 transition-colors pl-6 py-2">
								<h3 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">
									<a href={`/blog/${post.slug}`}>{post.data.title}</a>
								</h3>
								<p class="text-sm text-slate-600 mb-2">
									{post.data.date.toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</p>
								<p class="text-slate-700">{post.data.description}</p>
							</article>
						))}
					</div>
				</section>
			)}

			<section>
				<h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-4">Connect</h2>
				<div class="flex gap-6">
					{config.socials.map((social) => (
						<a 
							href={social.url} 
							target="_blank"
							rel="noopener noreferrer"
							class="text-slate-600 hover:text-blue-600 font-medium transition-colors"
						>
							{social.platform}
						</a>
					))}
				</div>
			</section>
		</main>
	</body>
</html>
