---
import { getCollection, render } from 'astro:content';
import config from '../../data/config.json';
import '../../styles/global.css';

export async function getStaticPaths() {
	const blogEntries = await getCollection('blog');
	return blogEntries.map(entry => ({
		params: { slug: entry.id.replace(/\.mdx?$/, '') },
		props: { entry },
	}));
}

interface Props {
	entry: any;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || '';
const slug = entry.id.replace(/\.mdx?$/, '');
const canonicalUrl = Astro.url.href;

const categoryMap: Record<string, string> = {
	'agentic-ai-compliance': 'AI',
	'claude-mythos-5': 'AI',
	'edge-computing-2026': 'Cloud',
	'enterprise-devops-modernization': 'DevOps',
	'finops-best-practices': 'FinOps',
	'metadata-saturation': 'Analytics',
	'retail-banking-api-architecture': 'Architecture',
	'zero-trust-cloud-security': 'Security',
};

const keywordsMap: Record<string, string[]> = {
	'agentic-ai-compliance': ['AI', 'Compliance', 'LangGraph', 'Python', 'Agentic AI'],
	'claude-mythos-5': ['AI', 'Claude', 'Anthropic', 'LLM', 'Reasoning'],
	'edge-computing-2026': ['Edge Computing', 'Cloud', 'K3s', 'Kubernetes', 'Infrastructure'],
	'enterprise-devops-modernization': ['DevOps', 'GitHub', 'CI/CD', 'Platform Engineering', 'DORA'],
	'finops-best-practices': ['FinOps', 'AWS', 'Azure', 'Cloud Cost', 'Optimization'],
	'metadata-saturation': ['Spatial Analytics', 'Edge Computing', 'Video Analytics', 'IoT'],
	'retail-banking-api-architecture': ['Banking', 'API', 'Microservices', 'Open Banking', 'Payments'],
	'zero-trust-cloud-security': ['Zero Trust', 'Security', 'AWS', 'Azure', 'IAM'],
};

const category = categoryMap[slug] || 'Tech';
const keywords = keywordsMap[slug] || [category];

const jsonLdBlogPosting = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: entry.data.title,
	description: entry.data.description,
	datePublished: entry.data.date.toISOString(),
	dateModified: entry.data.date.toISOString(),
	url: canonicalUrl,
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
	author: {
		'@type': 'Person',
		name: config.name,
		url: siteUrl,
	},
	keywords: keywords.join(', '),
	about: keywords.map(k => ({ '@type': 'Thing', name: k })),
	articleSection: category,
};

const jsonLdBreadcrumb = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
		{ '@type': 'ListItem', position: 3, name: entry.data.title, item: canonicalUrl },
	],
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="index, follow" />
		<meta name="description" content={entry.data.description} />
		<meta name="keywords" content={keywords.join(', ')} />
		<link rel="canonical" href={canonicalUrl} />
		<!-- Open Graph -->
		<meta property="og:type" content="article" />
		<meta property="og:title" content={entry.data.title} />
		<meta property="og:description" content={entry.data.description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={config.name} />
		<meta property="article:published_time" content={entry.data.date.toISOString()} />
		<meta property="article:author" content={config.name} />
		<meta property="article:section" content={category} />
		{keywords.map((tag) => (
			<meta property="article:tag" content={tag} />
		))}
		<!-- Twitter -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={entry.data.title} />
		<meta name="twitter:description" content={entry.data.description} />
		<title>{entry.data.title} | {config.name}</title>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLdBlogPosting)}></script>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)}></script>
		<style is:global>
			.prose {
				@apply max-w-2xl;
			}
			.prose p {
				@apply text-base leading-relaxed text-slate-700 mb-4;
			}
			.prose h1 {
				@apply text-4xl font-bold text-slate-950 mt-8 mb-4;
			}
			.prose h1:first-child {
				display: none;
			}
			.prose h2 {
				@apply text-2xl font-bold text-slate-950 mt-6 mb-3;
			}
			.prose h3 {
				@apply text-xl font-semibold text-slate-900 mt-4 mb-2;
			}
			.prose code {
				@apply bg-slate-100 text-slate-900 px-2 py-1 rounded text-sm font-mono;
			}
			.prose pre {
				@apply bg-slate-900 text-slate-50 p-4 rounded-lg overflow-x-auto mb-4;
			}
			.prose pre code {
				@apply bg-transparent text-inherit px-0 py-0 rounded-none;
			}
			.prose a {
				@apply text-blue-600 hover:underline;
			}
			.prose ul,
			.prose ol {
				@apply ml-6 mb-4;
			}
			.prose li {
				@apply mb-2;
			}
			.prose blockquote {
				@apply border-l-4 border-slate-300 pl-4 italic text-slate-600 my-4;
			}
		</style>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans">
		<div class="gradient-bar"></div>

		<main class="max-w-2xl mx-auto py-16 px-6">
			<header class="mb-12">
				<a href={base} class="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors mb-6">
					← Back to Home
				</a>
				<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 sm:p-8">
					<h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3 text-slate-950">{entry.data.title}</h1>
					<div class="flex items-center gap-3 text-sm text-slate-500">
						<div class="w-7 h-7 rounded-full bg-gradient-to-br from-blue-500 to-violet-600 flex items-center justify-center text-white font-bold text-xs">JS</div>
						<span>{config.name}</span>
					</div>
				</div>
			</header>

			<article class="prose prose-slate bg-white rounded-xl border border-slate-200 shadow-sm p-6 sm:p-8">
				<Content />
			</article>

			<div class="mt-8 text-center">
				<a href={base} class="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
					← Back to all posts
				</a>
			</div>
		</main>

		<footer class="border-t border-slate-200 bg-white py-8 mt-8">
			<div class="max-w-2xl mx-auto px-6 flex flex-col items-center gap-4">
				<div class="flex flex-wrap justify-center gap-3">
					{config.socials.map((social) => (
						<a
							href={social.url}
							target="_blank"
							rel="noopener noreferrer"
							class="social-pill inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 bg-slate-100 hover:bg-blue-50 hover:text-blue-600 px-3 py-1.5 rounded-full transition-colors"
						>
							{social.platform}
						</a>
					))}
				</div>
				<p class="text-xs text-slate-400">&copy; {new Date().getFullYear()} {config.name}. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>
