	'penetration-testing-methodology': 'Security', 'cloud-region-strategy': 'Cloud', 'fine-tuning-small-models': 'AI',
	'dependency-management-guide': 'DevOps', 'web-application-firewalls': 'Security', 'cloud-migration-7-rs': 'Cloud',
	'rlhf-visualized': 'AI', 'deployment-strategies-compared': 'DevOps', 'api-rate-limiting-algorithms': 'Security',
	'kubernetes-storage-explained': 'Cloud', 'ai-guardrails-guide': 'AI', 'graphql-rest-grpc-compared': 'DevOps',
	'secrets-in-cicd-pipelines': 'Security', 'dns-explained-visual': 'Cloud', 'semantic-vs-keyword-search': 'AI',
	'caching-strategies-guide': 'DevOps', 'threat-modeling-stride': 'Security', 'data-pipeline-architecture': 'Cloud',
	'transformer-architecture-visual': 'AI', 'database-connection-pooling': 'Cloud',
	'quantum-computing-beginners-guide': 'Quantum', 'qubits-vs-classical-bits': 'Quantum',
	'quantum-entanglement-explained': 'Quantum', 'quantum-gates-visualized': 'Quantum',
	'quantum-programming-qiskit-getting-started': 'Quantum', 'quantum-algorithms-grover-shor-explained': 'Quantum',
	'quantum-computing-real-world-applications': 'Quantum', 'quantum-computing-cloud-hands-on': 'Quantum',
	'quantum-security-encryption-future': 'Quantum', 'quantum-computing-future-roadmap': 'Quantum',
};

function getCategory(id: string): string {
	const slug = id.replace(/\.mdx?$/, '');
	return categoryMap[slug] || 'Tech';
}

export async function getStaticPaths({ paginate }) {
	const allPosts = await getCollection('blog');

	const cMap: Record<string, string> = {
		'agentic-ai-compliance': 'AI', 'agentic-loop-production': 'AI', 'langgraph-state-management': 'AI',
		'prompt-engineering-visual-playbook': 'AI', 'rag-pipelines-explained': 'AI', 'fine-tuning-vs-rag-vs-prompting': 'AI',
		'how-embeddings-work': 'AI', 'ai-agents-tool-use': 'AI', 'claude-mythos-5': 'AI',
		'edge-computing-2026': 'Cloud', 'enterprise-devops-modernization': 'DevOps', 'finops-best-practices': 'FinOps',
		'metadata-saturation': 'Analytics', 'retail-banking-api-architecture': 'Architecture', 'securing-openclaw': 'Security',
		'zero-trust-cloud-security': 'Security', 'multi-agent-systems': 'AI', 'feature-flags-done-right': 'DevOps',
		'supply-chain-attacks-explained': 'Security', 'kubernetes-networking-explained': 'Cloud',
		'ai-hallucinations-decoded': 'AI', 'oauth2-oidc-visual-guide': 'Security', 'cicd-pipeline-anatomy': 'DevOps',
		'serverless-vs-containers': 'Cloud', 'token-limits-explained': 'AI', 'secrets-management-guide': 'Security',
		'gitops-from-scratch': 'DevOps', 'cloud-cost-optimization': 'Cloud', 'attention-mechanisms-visual-guide': 'AI',
		'api-security-owasp-top-10': 'Security', 'observability-logs-metrics-traces': 'DevOps',
		'multi-cloud-strategy': 'Cloud', 'vector-databases-explained': 'AI', 'zero-trust-architecture-2026': 'Security',
		'infrastructure-as-code-compared': 'Cloud', 'prompt-caching-context-windows': 'AI',
		'rag-patterns-beyond-naive': 'AI', 'canary-deployments-guide': 'DevOps',
		'container-security-image-to-runtime': 'Security', 'service-mesh-explained': 'Cloud',
		'prompt-injection-attacks': 'AI', 'trunk-based-vs-gitflow': 'DevOps', 'encryption-rest-vs-transit': 'Security',
		'cloud-load-balancing-l4-l7': 'Cloud', 'mixture-of-experts-explained': 'AI', 'platform-engineering-guide': 'DevOps',
		'incident-response-playbook': 'Security', 'event-driven-architecture': 'Cloud', 'llm-evaluation-guide': 'AI',
		'docker-multi-stage-builds': 'DevOps', 'sast-dast-iast-compared': 'Security', 'managed-kubernetes-compared': 'Cloud',
		'ai-agent-memory-systems': 'AI', 'slos-slis-error-budgets': 'DevOps', 'certificate-management-tls': 'Security',
		'database-scaling-patterns': 'Cloud', 'chain-of-thought-reasoning': 'AI', 'monorepo-vs-polyrepo': 'DevOps',
		'cloud-iam-least-privilege': 'Security', 'cdn-architecture-explained': 'Cloud', 'model-distillation-guide': 'AI',
		'terraform-state-management': 'DevOps', 'security-headers-guide': 'Security',
		'message-queues-vs-event-streams': 'Cloud', 'multimodal-ai-explained': 'AI', 'helm-charts-demystified': 'DevOps',
		'penetration-testing-methodology': 'Security', 'cloud-region-strategy': 'Cloud', 'fine-tuning-small-models': 'AI',
		'dependency-management-guide': 'DevOps', 'web-application-firewalls': 'Security', 'cloud-migration-7-rs': 'Cloud',
		'rlhf-visualized': 'AI', 'deployment-strategies-compared': 'DevOps', 'api-rate-limiting-algorithms': 'Security',
		'kubernetes-storage-explained': 'Cloud', 'ai-guardrails-guide': 'AI', 'graphql-rest-grpc-compared': 'DevOps',
		'secrets-in-cicd-pipelines': 'Security', 'dns-explained-visual': 'Cloud', 'semantic-vs-keyword-search': 'AI',
		'caching-strategies-guide': 'DevOps', 'threat-modeling-stride': 'Security', 'data-pipeline-architecture': 'Cloud',
		'transformer-architecture-visual': 'AI', 'database-connection-pooling': 'Cloud',
		'quantum-computing-beginners-guide': 'Quantum', 'qubits-vs-classical-bits': 'Quantum',
		'quantum-entanglement-explained': 'Quantum', 'quantum-gates-visualized': 'Quantum',
		'quantum-programming-qiskit-getting-started': 'Quantum', 'quantum-algorithms-grover-shor-explained': 'Quantum',
		'quantum-computing-real-world-applications': 'Quantum', 'quantum-computing-cloud-hands-on': 'Quantum',
		'quantum-security-encryption-future': 'Quantum', 'quantum-computing-future-roadmap': 'Quantum',
	};

	const feat = [
		'transformer-architecture-visual', 'zero-trust-architecture-2026', 'kubernetes-networking-explained',
		'cicd-pipeline-anatomy', 'rlhf-visualized', 'prompt-injection-attacks', 'serverless-vs-containers',
		'docker-multi-stage-builds', 'graphql-rest-grpc-compared', 'container-security-image-to-runtime',
		'cloud-load-balancing-l4-l7', 'deployment-strategies-compared', 'ai-hallucinations-decoded',
		'api-rate-limiting-algorithms', 'dns-explained-visual', 'rag-pipelines-explained',
		'secrets-management-guide', 'cloud-cost-optimization', 'caching-strategies-guide',
		'mixture-of-experts-explained', 'oauth2-oidc-visual-guide', 'kubernetes-storage-explained',
		'observability-logs-metrics-traces', 'fine-tuning-small-models',
		'quantum-computing-beginners-guide', 'qubits-vs-classical-bits',
		'quantum-entanglement-explained', 'quantum-algorithms-grover-shor-explained',
		'quantum-security-encryption-future', 'quantum-computing-cloud-hands-on',
	];

	const sl = (p: any) => p.id.replace(/\.mdx?$/, '');
	const featSet = new Set(feat);
	const top: any[] = [];
	const rest: any[] = [];
	for (const p of allPosts) {
		if (featSet.has(sl(p))) top.push(p);
		else rest.push(p);
	}
	top.sort((a, b) => feat.indexOf(sl(a)) - feat.indexOf(sl(b)));
	rest.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
	const bycat: Record<string, any[]> = {};
	for (const p of rest) {
		const c = cMap[sl(p)] || 'Tech';
		if (!bycat[c]) bycat[c] = [];
		bycat[c].push(p);
	}
	const cats = Object.keys(bycat).sort((a, b) => bycat[b].length - bycat[a].length);
	const interleaved: any[] = [];
	const mx = Math.max(...cats.map(c => bycat[c].length), 0);
	for (let i = 0; i < mx; i++) {
		for (const c of cats) {
			if (i < bycat[c].length) interleaved.push(bycat[c][i]);
		}
	}
	const ordered = [...top, ...interleaved];
	return paginate(ordered, { pageSize: 6 });
}

const { page } = Astro.props;
const allPosts = await getCollection('blog');
const totalPages = Math.ceil(allPosts.length / 6);
const pageTitle = `Blog - ${config.name} | Cloud Architecture, AI Expert & Technical Leadership`;
const pageDescription = 'Latest insights on cloud architecture, AI expertise, and technical leadership from Jaswinder Singh.';
const canonical = page.currentPage === 1 ? '/blog/' : `/blog/${page.currentPage}/`;

function getCategoryStyle(category: string): { bg: string; text: string; border: string; dot: string } {
	const styles: Record<string, { bg: string; text: string; border: string; dot: string }> = {
		'AI': { bg: 'bg-violet-50', text: 'text-violet-700', border: 'border-violet-200', dot: 'bg-violet-500' },
		'Cloud': { bg: 'bg-sky-50', text: 'text-sky-700', border: 'border-sky-200', dot: 'bg-sky-500' },
		'DevOps': { bg: 'bg-emerald-50', text: 'text-emerald-700', border: 'border-emerald-200', dot: 'bg-emerald-500' },
		'FinOps': { bg: 'bg-amber-50', text: 'text-amber-700', border: 'border-amber-200', dot: 'bg-amber-500' },
		'Analytics': { bg: 'bg-rose-50', text: 'text-rose-700', border: 'border-rose-200', dot: 'bg-rose-500' },
		'Architecture': { bg: 'bg-indigo-50', text: 'text-indigo-700', border: 'border-indigo-200', dot: 'bg-indigo-500' },
		'Security': { bg: 'bg-red-50', text: 'text-red-700', border: 'border-red-200', dot: 'bg-red-500' },
		'Quantum': { bg: 'bg-fuchsia-50', text: 'text-fuchsia-700', border: 'border-fuchsia-200', dot: 'bg-fuchsia-500' },
	};
	return styles[category] || { bg: 'bg-slate-50', text: 'text-slate-700', border: 'border-slate-200', dot: 'bg-slate-500' };
}
---

<MainLayout title={pageTitle} description={pageDescription} canonical={canonical} keywords={['Cloud Architecture', 'AI Expert', 'Technical Leadership', 'Blog', 'AI', 'Cloud']}>
	<main class="max-w-4xl mx-auto py-16 px-6">
		<div class="mb-12 text-center">
			<div class="mb-8">
				<a href="/" class="inline-flex items-center gap-3 text-base font-semibold text-blue-600 hover:text-blue-800 transition-colors">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
					</svg>
					Back to Home
				</a>
			</div>
			<h1 class="text-4xl font-bold tracking-tight text-slate-950 mb-4">Blog</h1>
			<p class="text-lg text-slate-600 max-w-2xl mx-auto">Thoughts on technology, AI, and building scalable systems.</p>
		</div>

		<div class="space-y-6">
			{page.data.map((post) => {
				const cat = getCategory(post.id);
				const style = getCategoryStyle(cat);
				return (
					<article class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden card-hover">
						<a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="block p-6 no-underline group">
							<div class="flex items-start justify-between gap-4 mb-4">
								<div class="flex-1 min-w-0">
									<h2 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition-colors leading-tight">{post.data.title}</h2>
									<p class="text-base text-slate-600 mb-4 leading-relaxed">{post.data.description}</p>
								</div>
								<span class={`shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full ${style.bg} ${style.text} text-xs font-semibold`}>
									<span class={`w-2 h-2 rounded-full ${style.dot}`}></span>
									{cat}
								</span>
							</div>
							<div class="flex items-center justify-between">
								<time datetime={post.data.date.toISOString()} class="text-sm text-slate-500">
									{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
								</time>
								<span class="text-sm text-blue-600 group-hover:text-blue-700 font-medium transition-colors">Read more →</span>
							</div>
						</a>
					</article>
				);
			})}
		</div>

		{totalPages > 1 && (
			<div class="mt-16 flex items-center justify-center gap-3">
				{page.currentPage > 1 && (
					<a href={page.currentPage === 2 ? '/blog/' : `/blog/${page.currentPage - 1}`} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 hover:border-slate-400 transition-all duration-200 shadow-sm">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
						Previous
					</a>
				)}

				<div class="flex items-center gap-2">
					{Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => (
						<a href={pageNum === 1 ? '/blog/' : `/blog/${pageNum}`} class={`px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 ${pageNum === page.currentPage ? 'bg-blue-600 text-white shadow-md' : 'text-slate-700 bg-white border border-slate-300 hover:bg-slate-50 hover:border-slate-400 shadow-sm'}`}>
							{pageNum}
						</a>
					))}
				</div>

				{page.currentPage < totalPages && (
					<a href={`/blog/${page.currentPage + 1}`} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 hover:border-slate-400 transition-all duration-200 shadow-sm">
						Next
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
					</a>
				)}
			</div>
		)}
	</main>
</MainLayout>
