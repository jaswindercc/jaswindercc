---
// FlagMetrics.astro — Before/after metrics with feature flags
---
<div class="fm-wrap">
  <h3 class="fm-title">Before Flags vs After Flags — The Numbers</h3>
  <p class="fm-sub">Same team. Same product. Feature flags changed how they ship.</p>
  <div class="fm-grid">
    <div class="fm-card"><div class="fm-label">Deploy Frequency</div><div class="fm-row"><span class="fm-tag">Before</span><div class="fm-track"><div class="fm-bar fm-b--red" style="--w:15%"></div></div><span class="fm-val fm-r">2/month</span></div><div class="fm-row"><span class="fm-tag">After</span><div class="fm-track"><div class="fm-bar fm-b--green" style="--w:85%"></div></div><span class="fm-val fm-g">12/day</span></div></div>
    <div class="fm-card"><div class="fm-label">Rollback Time</div><div class="fm-row"><span class="fm-tag">Before</span><div class="fm-track"><div class="fm-bar fm-b--red" style="--w:80%"></div></div><span class="fm-val fm-r">45 min</span></div><div class="fm-row"><span class="fm-tag">After</span><div class="fm-track"><div class="fm-bar fm-b--green" style="--w:5%"></div></div><span class="fm-val fm-g">3 sec</span></div></div>
    <div class="fm-card"><div class="fm-label">Incident Rate</div><div class="fm-row"><span class="fm-tag">Before</span><div class="fm-track"><div class="fm-bar fm-b--red" style="--w:60%"></div></div><span class="fm-val fm-r">4/month</span></div><div class="fm-row"><span class="fm-tag">After</span><div class="fm-track"><div class="fm-bar fm-b--green" style="--w:12%"></div></div><span class="fm-val fm-g">0.5/month</span></div></div>
    <div class="fm-card"><div class="fm-label">Time to Full Rollout</div><div class="fm-row"><span class="fm-tag">Before</span><div class="fm-track"><div class="fm-bar fm-b--red" style="--w:70%"></div></div><span class="fm-val fm-r">Big bang</span></div><div class="fm-row"><span class="fm-tag">After</span><div class="fm-track"><div class="fm-bar fm-b--green" style="--w:40%"></div></div><span class="fm-val fm-g">7-10 days</span></div></div>
  </div>
</div>
<style>
  .fm-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border-radius:16px;padding:2rem;margin:2rem 0;border:1px solid #334155}
  .fm-title{color:#f1f5f9;font-size:1.15rem;font-weight:700;margin:0 0 .25rem}.fm-sub{color:#64748b;font-size:.8rem;margin:0 0 1.5rem;font-family:monospace}
  .fm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
  .fm-card{background:rgba(0,0,0,.25);border:1px solid #334155;border-radius:12px;padding:14px}
  .fm-label{color:#e2e8f0;font-size:.78rem;font-weight:700;margin-bottom:10px}
  .fm-row{display:flex;align-items:center;gap:6px;margin-bottom:5px}
  .fm-tag{color:#64748b;font-size:.5rem;font-family:monospace;min-width:34px;text-align:right}
  .fm-track{flex:1;height:16px;background:rgba(0,0,0,.3);border-radius:4px;overflow:hidden}
  .fm-bar{height:100%;border-radius:4px;width:0;animation:fmG 1s ease-out .5s forwards}
  .fm-b--red{background:#ef4444}.fm-b--green{background:#4ade80}
  .fm-val{font-size:.6rem;font-family:monospace;font-weight:700;min-width:52px}
  .fm-r{color:#f87171}.fm-g{color:#4ade80}
  @keyframes fmG{to{width:var(--w)}}
</style>
