---
// TraceViewError.astro — Pure CSS animated trace view showing a real production error‑recovery sequence
// The "hero" animation: watch an agent hit a timeout, retry, cost spike, and recover
---

<div class="tv-wrap">
  <h3 class="tv-title">🔴 Live Trace — Error Recovery in Production</h3>
  <p class="tv-sub">Watch the agent hit a wall, burn tokens retrying, and eventually self-correct.</p>

  <div class="tv-header">
    <span class="tv-badge tv-badge--live">● TRACE</span>
    <span class="tv-id">trace-id: 8f3a-c2e1-prod</span>
    <span class="tv-dur">total: 14.2s</span>
  </div>

  <div class="tv-timeline">
    <div class="tv-line" aria-hidden="true"></div>

    <!-- Step 1: Plan -->
    <div class="tv-step tv-step--ok" style="--delay: 0.2s">
      <div class="tv-dot tv-dot--amber"></div>
      <div class="tv-card">
        <div class="tv-head">
          <span class="tv-tag tv-tag--amber">PLAN</span>
          <span class="tv-agent">orchestrator</span>
          <span class="tv-ts">+0.12s</span>
          <span class="tv-cost">$0.002</span>
        </div>
        <div class="tv-body">"Summarize customer complaint #4821. Need to call sentiment API, then lookup history, then draft response."</div>
        <div class="tv-latbar"><div class="tv-latfill tv-latfill--ok" style="--w:8%"></div></div>
      </div>
    </div>

    <!-- Step 2: Act — sentiment API -->
    <div class="tv-step tv-step--ok" style="--delay: 0.4s">
      <div class="tv-dot tv-dot--cyan"></div>
      <div class="tv-card">
        <div class="tv-head">
          <span class="tv-tag tv-tag--cyan">ACT</span>
          <span class="tv-agent">sentiment_api</span>
          <span class="tv-ts">+0.34s</span>
          <span class="tv-cost">$0.001</span>
        </div>
        <div class="tv-body">
          <code>analyze_sentiment(text="I've been waiting 3 weeks...")</code>
          <div class="tv-result tv-result--ok">→ negative (0.91 confidence)</div>
        </div>
        <div class="tv-latbar"><div class="tv-latfill tv-latfill--ok" style="--w:12%"></div></div>
      </div>
    </div>

    <!-- Step 3: Act — history lookup — TIMEOUT -->
    <div class="tv-step tv-step--error" style="--delay: 0.6s">
      <div class="tv-dot tv-dot--red tv-dot--pulse"></div>
      <div class="tv-card tv-card--error">
        <div class="tv-head">
          <span class="tv-tag tv-tag--red">ACT</span>
          <span class="tv-agent">history_lookup</span>
          <span class="tv-ts">+3.40s</span>
          <span class="tv-cost">$0.000</span>
        </div>
        <div class="tv-body">
          <code>get_customer_history(id="CUS-4821")</code>
          <div class="tv-result tv-result--red">✗ TIMEOUT after 3000ms — DB connection pool exhausted</div>
        </div>
        <div class="tv-latbar"><div class="tv-latfill tv-latfill--red" style="--w:85%"></div></div>
      </div>
    </div>

    <!-- Step 4: Observe — agent notices failure -->
    <div class="tv-step tv-step--warn" style="--delay: 0.8s">
      <div class="tv-dot tv-dot--amber"></div>
      <div class="tv-card tv-card--warn">
        <div class="tv-head">
          <span class="tv-tag tv-tag--amber">OBSERVE</span>
          <span class="tv-agent">orchestrator</span>
          <span class="tv-ts">+3.42s</span>
          <span class="tv-cost">$0.003</span>
        </div>
        <div class="tv-body">"history_lookup failed. I could retry — but the same pool is likely still exhausted. Let me try the cache API instead."</div>
      </div>
    </div>

    <!-- Step 5: Refine — switch strategy -->
    <div class="tv-step tv-step--ok" style="--delay: 1.0s">
      <div class="tv-dot tv-dot--green"></div>
      <div class="tv-card">
        <div class="tv-head">
          <span class="tv-tag tv-tag--green">REFINE</span>
          <span class="tv-agent">orchestrator</span>
          <span class="tv-ts">+3.50s</span>
          <span class="tv-cost">$0.004</span>
        </div>
        <div class="tv-body">"Switching to cache_lookup. If that fails too, I'll skip history and note it as missing context."</div>
      </div>
    </div>

    <!-- Step 6: Act — cache fallback — SUCCESS -->
    <div class="tv-step tv-step--ok" style="--delay: 1.2s">
      <div class="tv-dot tv-dot--cyan"></div>
      <div class="tv-card">
        <div class="tv-head">
          <span class="tv-tag tv-tag--cyan">ACT</span>
          <span class="tv-agent">cache_lookup</span>
          <span class="tv-ts">+3.72s</span>
          <span class="tv-cost">$0.001</span>
        </div>
        <div class="tv-body">
          <code>get_cached_history(id="CUS-4821")</code>
          <div class="tv-result tv-result--ok">→ 3 prior tickets found (last: 12 days ago, topic: "shipping delay")</div>
        </div>
        <div class="tv-latbar"><div class="tv-latfill tv-latfill--ok" style="--w:10%"></div></div>
      </div>
    </div>

    <!-- Step 7: Act — draft response -->
    <div class="tv-step tv-step--ok" style="--delay: 1.4s">
      <div class="tv-dot tv-dot--cyan"></div>
      <div class="tv-card">
        <div class="tv-head">
          <span class="tv-tag tv-tag--cyan">ACT</span>
          <span class="tv-agent">draft_response</span>
          <span class="tv-ts">+5.10s</span>
          <span class="tv-cost">$0.008</span>
        </div>
        <div class="tv-body">
          <code>generate_reply(sentiment="negative", history=3, context="shipping")</code>
          <div class="tv-result tv-result--ok">→ Draft generated (142 tokens, empathetic tone, escalation offer)</div>
        </div>
        <div class="tv-latbar"><div class="tv-latfill tv-latfill--ok" style="--w:35%"></div></div>
      </div>
    </div>

    <!-- Step 8: Final log -->
    <div class="tv-step tv-step--done" style="--delay: 1.6s">
      <div class="tv-dot tv-dot--green tv-dot--glow"></div>
      <div class="tv-card tv-card--done">
        <div class="tv-head">
          <span class="tv-tag tv-tag--green">DONE</span>
          <span class="tv-agent">decision_log</span>
          <span class="tv-ts">+5.14s</span>
          <span class="tv-cost-total">total: $0.019</span>
        </div>
        <div class="tv-flag">
          <div class="tv-flag-row"><span class="tv-flag-key">Ticket:</span> #4821</div>
          <div class="tv-flag-row"><span class="tv-flag-key">Recovery:</span> <span class="tv-flag-yes">cache fallback (history_lookup timeout)</span></div>
          <div class="tv-flag-row"><span class="tv-flag-key">Retries:</span> 0 (smart skip)</div>
          <div class="tv-flag-row"><span class="tv-flag-key">Output:</span> <span class="tv-flag-yes">✓ Draft ready for human review</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="tv-insight">
    <div class="tv-insight-icon">🔑</div>
    <div>The agent didn't blindly retry. It <strong>reasoned about the failure</strong>, picked a cheaper fallback, and logged why. That's the difference between a demo and production.</div>
  </div>
</div>

<style>
  .tv-wrap {
    background: linear-gradient(135deg, #0f172a 0%, #1a1028 50%, #1e293b 100%);
    border-radius: 16px;
    padding: 2rem;
    margin: 2rem 0;
    border: 1px solid #334155;
    position: relative;
    overflow: hidden;
  }
  .tv-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #ef4444, #f59e0b, #4ade80);
    opacity: 0.6;
  }
  .tv-title { color: #f1f5f9; font-size: 1.15rem; font-weight: 700; margin: 0 0 0.25rem; }
  .tv-sub { color: #64748b; font-size: 0.8rem; margin: 0 0 1rem; font-family: monospace; }

  .tv-header {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    padding: 8px 14px; background: rgba(0,0,0,0.3); border-radius: 8px;
    margin-bottom: 1.5rem; border: 1px solid #334155;
  }
  .tv-badge { font-family: monospace; font-size: 0.6rem; font-weight: 700; padding: 2px 8px; border-radius: 4px; }
  .tv-badge--live { background: rgba(239,68,68,0.15); color: #f87171; animation: tv-blink 2s infinite; }
  @keyframes tv-blink { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
  .tv-id { font-family: monospace; font-size: 0.6rem; color: #64748b; }
  .tv-dur { font-family: monospace; font-size: 0.6rem; color: #94a3b8; margin-left: auto; }

  .tv-timeline { position: relative; padding-left: 28px; }
  .tv-line {
    position: absolute; left: 9px; top: 0; bottom: 0; width: 2px;
    background: linear-gradient(180deg, #f59e0b40, #ef444480, #4ade8040);
  }

  .tv-step {
    position: relative; margin-bottom: 10px;
    animation: tv-slide 0.5s ease-out both;
    animation-delay: var(--delay, 0s);
  }
  @keyframes tv-slide {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .tv-dot {
    position: absolute; left: -24px; top: 12px;
    width: 12px; height: 12px; border-radius: 50%;
  }
  .tv-dot--amber { background: #f59e0b; box-shadow: 0 0 8px rgba(245,158,11,0.4); }
  .tv-dot--cyan  { background: #06b6d4; box-shadow: 0 0 8px rgba(6,182,212,0.4); }
  .tv-dot--green { background: #4ade80; box-shadow: 0 0 8px rgba(74,222,128,0.4); }
  .tv-dot--red   { background: #ef4444; box-shadow: 0 0 8px rgba(239,68,68,0.4); }
  .tv-dot--pulse { animation: tv-pulse-red 1.5s infinite; }
  .tv-dot--glow  { animation: tv-glow-green 2s infinite; }
  @keyframes tv-pulse-red {
    0%,100% { box-shadow: 0 0 8px rgba(239,68,68,0.4); }
    50% { box-shadow: 0 0 20px rgba(239,68,68,0.8); }
  }
  @keyframes tv-glow-green {
    0%,100% { box-shadow: 0 0 8px rgba(74,222,128,0.4); }
    50% { box-shadow: 0 0 16px rgba(74,222,128,0.7); }
  }

  .tv-card {
    background: rgba(0,0,0,0.25); border: 1px solid #334155;
    border-radius: 10px; padding: 10px 14px;
    transition: border-color 0.3s;
  }
  .tv-card:hover { border-color: #475569; }
  .tv-card--error { border-color: #ef444440; background: rgba(239,68,68,0.04); }
  .tv-card--warn  { border-color: #f59e0b30; background: rgba(245,158,11,0.03); }
  .tv-card--done  { border-color: #4ade8030; background: rgba(74,222,128,0.04); }

  .tv-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
  .tv-tag {
    font-family: monospace; font-size: 0.55rem; font-weight: 700;
    letter-spacing: 0.5px; padding: 2px 7px; border-radius: 4px;
  }
  .tv-tag--amber { background: rgba(245,158,11,0.12); color: #f59e0b; }
  .tv-tag--cyan  { background: rgba(6,182,212,0.12); color: #06b6d4; }
  .tv-tag--green { background: rgba(74,222,128,0.12); color: #4ade80; }
  .tv-tag--red   { background: rgba(239,68,68,0.12); color: #f87171; }

  .tv-agent { font-family: monospace; font-size: 0.6rem; color: #64748b; }
  .tv-ts { font-family: monospace; font-size: 0.55rem; color: #475569; margin-left: auto; }
  .tv-cost { font-family: monospace; font-size: 0.55rem; color: #94a3b8; }
  .tv-cost-total { font-family: monospace; font-size: 0.6rem; color: #4ade80; font-weight: 700; }

  .tv-body { font-size: 0.75rem; color: #94a3b8; line-height: 1.5; }
  .tv-body code {
    display: block; font-size: 0.65rem; color: #67e8f9;
    background: rgba(6,182,212,0.06); padding: 4px 8px;
    border-radius: 4px; margin-bottom: 4px; font-family: monospace;
  }
  .tv-result { font-family: monospace; font-size: 0.65rem; font-weight: 600; padding-top: 2px; }
  .tv-result--ok  { color: #4ade80; }
  .tv-result--red { color: #f87171; }

  .tv-latbar { height: 4px; background: #1e293b; border-radius: 2px; margin-top: 8px; overflow: hidden; }
  .tv-latfill { height: 100%; border-radius: 2px; width: 0; animation: tv-barfill 1.2s ease-out forwards; animation-delay: var(--delay, 0s); }
  .tv-latfill--ok  { background: linear-gradient(90deg, #22c55e, #4ade80); }
  .tv-latfill--red { background: linear-gradient(90deg, #ef4444, #f87171); }
  @keyframes tv-barfill { to { width: var(--w); } }

  .tv-flag {
    background: rgba(74,222,128,0.04); border: 1px dashed #4ade8030;
    border-radius: 6px; padding: 8px 10px; margin-top: 4px;
  }
  .tv-flag-row { font-family: monospace; font-size: 0.65rem; color: #94a3b8; line-height: 1.7; }
  .tv-flag-key { color: #64748b; }
  .tv-flag-yes { color: #4ade80; font-weight: 700; }

  .tv-insight {
    display: flex; align-items: flex-start; gap: 10px; margin-top: 16px;
    padding: 12px 16px; background: rgba(245,158,11,0.06);
    border: 1px solid rgba(245,158,11,0.15); border-radius: 10px;
    color: #cbd5e1; font-size: 0.8rem; line-height: 1.5;
  }
  .tv-insight strong { color: #f59e0b; }
  .tv-insight-icon { font-size: 1.1rem; flex-shrink: 0; }
</style>
