---
/**
 * SLOStack.astro
 * SLI → SLO → SLA hierarchy with error budget
 */
---

<div class="slo-wrap">
  <h3 class="slo-title">SLIs, SLOs, SLAs — The Reliability Stack</h3>
  <div class="slo-stack">
    <div class="slo-level" style="--i:0; --color:#ef4444;">
      <div class="slo-badge">SLA</div>
      <div class="slo-def">Service Level Agreement — contractual promise to customers</div>
      <div class="slo-ex">"99.9% uptime or we pay you credits"</div>
    </div>
    <div class="slo-arrow">↑ backed by</div>
    <div class="slo-level" style="--i:1; --color:#f59e0b;">
      <div class="slo-badge">SLO</div>
      <div class="slo-def">Service Level Objective — internal reliability target</div>
      <div class="slo-ex">"99.95% of requests succeed within 200ms" (tighter than SLA)</div>
    </div>
    <div class="slo-arrow">↑ measured by</div>
    <div class="slo-level" style="--i:2; --color:#4ade80;">
      <div class="slo-badge">SLI</div>
      <div class="slo-def">Service Level Indicator — the actual metric from production</div>
      <div class="slo-ex">Request success rate over 30 days = 99.97%</div>
    </div>
  </div>
  <div class="slo-budget">
    <div class="slo-budget-label">Error Budget (SLO = 99.95%)</div>
    <div class="slo-budget-bar">
      <div class="slo-budget-used" style="width:40%;">
        <span>40% used</span>
      </div>
      <div class="slo-budget-remain">
        <span>60% remaining — ship features</span>
      </div>
    </div>
    <div class="slo-budget-desc">0.05% = ~22 minutes of downtime per month. Spend wisely.</div>
  </div>
</div>

<style>
  .slo-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .slo-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .slo-stack{display:flex;flex-direction:column;gap:0;margin-bottom:1.5rem}
  .slo-level{background:rgba(255,255,255,0.03);border:1px solid var(--color);border-radius:12px;padding:1rem 1.25rem;opacity:0;animation:sloFade .5s ease forwards;animation-delay:calc(var(--i)*.2s)}
  @keyframes sloFade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .slo-badge{background:var(--color);color:#0f172a;font-size:.7rem;font-weight:700;padding:.15rem .5rem;border-radius:6px;display:inline-block;margin-bottom:.3rem}
  .slo-def{color:#f1f5f9;font-size:.85rem;margin-bottom:.15rem}
  .slo-ex{color:#94a3b8;font-size:.78rem;font-family:monospace}
  .slo-arrow{text-align:center;color:#64748b;font-size:.7rem;padding:.3rem 0}
  .slo-budget{background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.25);border-radius:10px;padding:1rem}
  .slo-budget-label{color:#f59e0b;font-weight:700;font-size:.9rem;margin-bottom:.5rem}
  .slo-budget-bar{display:flex;height:28px;border-radius:8px;overflow:hidden;background:rgba(0,0,0,.3)}
  .slo-budget-used{background:rgba(239,68,68,0.3);display:flex;align-items:center;justify-content:center}
  .slo-budget-used span{color:#ef4444;font-size:.65rem;font-weight:600}
  .slo-budget-remain{flex:1;display:flex;align-items:center;justify-content:center}
  .slo-budget-remain span{color:#4ade80;font-size:.65rem;font-weight:600}
  .slo-budget-desc{color:#94a3b8;font-size:.75rem;margin-top:.4rem}
</style>
