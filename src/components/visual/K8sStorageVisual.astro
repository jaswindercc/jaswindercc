---
/**
 * K8sStorageVisual.astro
 * Kubernetes storage concepts
 */
---

<div class="ksv-wrap">
  <h3 class="ksv-title">Kubernetes Storage Stack</h3>
  <div class="ksv-layers">
    <div class="ksv-layer" style="--i:0;--c:#818cf8;">
      <div class="ksv-lname">Pod</div>
      <div class="ksv-ldesc">Mounts volumes via volumeMounts spec</div>
      <div class="ksv-arrow">↓ references</div>
    </div>
    <div class="ksv-layer" style="--i:1;--c:#06b6d4;">
      <div class="ksv-lname">PersistentVolumeClaim (PVC)</div>
      <div class="ksv-ldesc">Request for storage — size, access mode, storage class</div>
      <div class="ksv-arrow">↓ binds to</div>
    </div>
    <div class="ksv-layer" style="--i:2;--c:#f59e0b;">
      <div class="ksv-lname">PersistentVolume (PV)</div>
      <div class="ksv-ldesc">Actual storage resource — pre-provisioned or dynamic</div>
      <div class="ksv-arrow">↓ backed by</div>
    </div>
    <div class="ksv-layer" style="--i:3;--c:#4ade80;">
      <div class="ksv-lname">StorageClass</div>
      <div class="ksv-ldesc">Provisioner config — gp3, io2, standard, premium-rwo</div>
      <div class="ksv-arrow">↓ provisions on</div>
    </div>
    <div class="ksv-layer" style="--i:4;--c:#ef4444;">
      <div class="ksv-lname">Physical Storage</div>
      <div class="ksv-ldesc">EBS, Azure Disk, GCE PD, NFS, Ceph, local SSD</div>
    </div>
  </div>
  <div class="ksv-modes">
    <h4 class="ksv-subtitle">Access Modes</h4>
    <div class="ksv-mode-grid">
      <div class="ksv-mode" style="--mc:#4ade80;">RWO<span>ReadWriteOnce — single node</span></div>
      <div class="ksv-mode" style="--mc:#06b6d4;">ROX<span>ReadOnlyMany — multi-node read</span></div>
      <div class="ksv-mode" style="--mc:#f59e0b;">RWX<span>ReadWriteMany — multi-node write</span></div>
    </div>
  </div>
</div>

<style>
  .ksv-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .ksv-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .ksv-layers{display:flex;flex-direction:column;align-items:center;gap:0}
  .ksv-layer{background:rgba(0,0,0,.2);border:1px solid var(--c);border-radius:10px;padding:.7rem 1.2rem;width:100%;max-width:400px;text-align:center;opacity:0;animation:ksvDrop .35s ease forwards;animation-delay:calc(var(--i)*.12s)}
  @keyframes ksvDrop{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
  .ksv-lname{color:var(--c);font-weight:700;font-size:.82rem}
  .ksv-ldesc{color:#94a3b8;font-size:.7rem;margin-top:.15rem}
  .ksv-arrow{color:#475569;font-size:.65rem;padding:.2rem 0;text-align:center}
  .ksv-modes{margin-top:1.5rem}
  .ksv-subtitle{color:#94a3b8;text-align:center;font-size:.85rem;margin:0 0 .75rem}
  .ksv-mode-grid{display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap}
  .ksv-mode{background:rgba(0,0,0,.2);border:1px solid var(--mc);border-radius:8px;padding:.5rem .8rem;color:var(--mc);font-weight:700;font-size:.8rem;display:flex;flex-direction:column;align-items:center;gap:.15rem}
  .ksv-mode span{color:#64748b;font-size:.62rem;font-weight:400}
</style>
