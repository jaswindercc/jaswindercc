---
/**
 * FineTuningVisual.astro
 * Fine-tuning decision and process flow
 */
---

<div class="ftv-wrap">
  <h3 class="ftv-title">When to Fine-Tune vs Alternatives</h3>
  <div class="ftv-flow">
    <div class="ftv-node ftv-start" style="--i:0;">Your task needs domain-specific behavior</div>
    <div class="ftv-arrow" style="--i:1;">↓</div>
    <div class="ftv-branch" style="--i:2;">
      <div class="ftv-path ftv-yes">
        <div class="ftv-q">Can prompting alone solve it?</div>
        <div class="ftv-a yes">YES → Prompt Engineering</div>
        <div class="ftv-cost">Cost: $0 | Time: hours</div>
      </div>
      <div class="ftv-path ftv-maybe">
        <div class="ftv-q">Need external knowledge?</div>
        <div class="ftv-a maybe">YES → RAG Pipeline</div>
        <div class="ftv-cost">Cost: $$ | Time: days</div>
      </div>
      <div class="ftv-path ftv-no">
        <div class="ftv-q">Need new behavior/style?</div>
        <div class="ftv-a no">YES → Fine-Tuning</div>
        <div class="ftv-cost">Cost: $$$ | Time: weeks</div>
      </div>
    </div>
    <div class="ftv-arrow" style="--i:3;">↓</div>
    <div class="ftv-steps" style="--i:4;">
      <div class="ftv-step" style="--j:0;--sc:#f59e0b;">Curate 500-10K examples</div>
      <div class="ftv-step" style="--j:1;--sc:#06b6d4;">Format as instruction pairs</div>
      <div class="ftv-step" style="--j:2;--sc:#818cf8;">Train with LoRA/QLoRA</div>
      <div class="ftv-step" style="--j:3;--sc:#4ade80;">Evaluate on held-out set</div>
      <div class="ftv-step" style="--j:4;--sc:#ef4444;">Deploy + monitor drift</div>
    </div>
  </div>
</div>

<style>
  .ftv-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .ftv-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .ftv-flow{display:flex;flex-direction:column;align-items:center;gap:.5rem}
  .ftv-start{background:rgba(129,140,248,.15);border:1px solid #818cf8;color:#c7d2fe;padding:.6rem 1.2rem;border-radius:8px;font-size:.8rem;opacity:0;animation:ftvFade .3s ease forwards;animation-delay:calc(var(--i)*.15s)}
  .ftv-arrow{color:#475569;font-size:1.2rem;opacity:0;animation:ftvFade .3s ease forwards;animation-delay:calc(var(--i)*.15s)}
  .ftv-branch{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;width:100%;opacity:0;animation:ftvFade .3s ease forwards;animation-delay:calc(var(--i)*.15s)}
  .ftv-path{background:rgba(0,0,0,.2);border-radius:10px;padding:.8rem;text-align:center}
  .ftv-q{color:#94a3b8;font-size:.72rem;margin-bottom:.4rem}
  .ftv-a{font-weight:700;font-size:.78rem;margin-bottom:.2rem}
  .ftv-a.yes{color:#4ade80}.ftv-a.maybe{color:#f59e0b}.ftv-a.no{color:#818cf8}
  .ftv-cost{color:#64748b;font-size:.65rem}
  .ftv-steps{display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center;opacity:0;animation:ftvFade .3s ease forwards;animation-delay:calc(var(--i)*.15s)}
  .ftv-step{background:rgba(0,0,0,.25);border:1px solid var(--sc);color:var(--sc);padding:.4rem .8rem;border-radius:20px;font-size:.7rem;font-weight:600;opacity:0;animation:ftvPop .3s ease forwards;animation-delay:calc(.6s + var(--j)*.08s)}
  @keyframes ftvFade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
  @keyframes ftvPop{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
</style>
