  .oat-n{font-family:monospace;font-size:.6rem;font-weight:800;color:#f87171;background:rgba(248,113,113,.1);padding:2px 6px;border-radius:4px;flex-shrink:0}
  .oat-nm{color:#e2e8f0;font-weight:700;font-size:.75rem;flex:1}.oat-sev{color:#f87171;font-size:.55rem;font-family:monospace}
