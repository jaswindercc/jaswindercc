---
/**
 * DataPipelineVisual.astro
 * Batch vs stream data pipeline architectures
 */
---

<div class="dpv-wrap">
  <h3 class="dpv-title">Data Pipeline Architectures</h3>
  <div class="dpv-pipes">
    <div class="dpv-pipe" style="--i:0;--c:#06b6d4;">
      <div class="dpv-pname">Batch Processing</div>
      <div class="dpv-flow">
        <div class="dpv-node">Sources</div>
        <div class="dpv-edge">→ collect →</div>
        <div class="dpv-node">Storage (S3/HDFS)</div>
        <div class="dpv-edge">→ schedule →</div>
        <div class="dpv-node">Process (Spark)</div>
        <div class="dpv-edge">→ load →</div>
        <div class="dpv-node">Warehouse</div>
      </div>
      <div class="dpv-meta">
        <span class="dpv-lat">Latency: minutes–hours</span>
        <span class="dpv-use">Analytics, ML training, reporting</span>
      </div>
    </div>
    <div class="dpv-pipe" style="--i:1;--c:#f59e0b;">
      <div class="dpv-pname">Stream Processing</div>
      <div class="dpv-flow">
        <div class="dpv-node">Sources</div>
        <div class="dpv-edge">→ publish →</div>
        <div class="dpv-node">Broker (Kafka)</div>
        <div class="dpv-edge">→ process →</div>
        <div class="dpv-node">Engine (Flink)</div>
        <div class="dpv-edge">→ sink →</div>
        <div class="dpv-node">Store / Alert</div>
      </div>
      <div class="dpv-meta">
        <span class="dpv-lat">Latency: ms–seconds</span>
        <span class="dpv-use">Real-time dashboards, fraud, alerts</span>
      </div>
    </div>
    <div class="dpv-pipe" style="--i:2;--c:#818cf8;">
      <div class="dpv-pname">Lambda Architecture</div>
      <div class="dpv-flow">
        <div class="dpv-node">Sources</div>
        <div class="dpv-edge">→ split →</div>
        <div class="dpv-node">Batch + Stream</div>
        <div class="dpv-edge">→ merge →</div>
        <div class="dpv-node">Serving Layer</div>
      </div>
      <div class="dpv-meta">
        <span class="dpv-lat">Both real-time + historical</span>
        <span class="dpv-use">Complex analytics with low-latency needs</span>
      </div>
    </div>
  </div>
</div>

<style>
  .dpv-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .dpv-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .dpv-pipes{display:flex;flex-direction:column;gap:1rem}
  .dpv-pipe{background:rgba(0,0,0,.2);border-radius:12px;padding:1rem;border-left:3px solid var(--c);opacity:0;animation:dpvSlide .4s ease forwards;animation-delay:calc(var(--i)*.15s)}
  @keyframes dpvSlide{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .dpv-pname{color:var(--c);font-weight:700;font-size:.88rem;margin-bottom:.6rem;text-align:center}
  .dpv-flow{display:flex;align-items:center;gap:.3rem;flex-wrap:wrap;justify-content:center;margin-bottom:.6rem}
  .dpv-node{background:rgba(255,255,255,.06);color:#e2e8f0;padding:.25rem .6rem;border-radius:6px;font-size:.7rem;font-weight:500}
  .dpv-edge{color:#475569;font-size:.65rem;white-space:nowrap}
  .dpv-meta{display:flex;justify-content:space-between;flex-wrap:wrap;gap:.3rem}
  .dpv-lat{color:var(--c);font-size:.68rem;font-weight:600}
  .dpv-use{color:#64748b;font-size:.65rem}
</style>
