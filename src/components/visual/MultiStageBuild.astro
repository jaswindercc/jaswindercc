---
/**
 * MultiStageBuild.astro
 * Multi-stage Docker build visualization
 */
const dockerExample = `<div class="msb-line"><span class="msb-kw">FROM</span> node:20 <span class="msb-kw">AS</span> builder</div>
<div class="msb-line"><span class="msb-kw">WORKDIR</span> /app</div>
<div class="msb-line"><span class="msb-kw">COPY</span> package*.json ./</div>
<div class="msb-line"><span class="msb-kw">RUN</span> npm ci</div>
<div class="msb-line"><span class="msb-kw">COPY</span> . .</div>
<div class="msb-line"><span class="msb-kw">RUN</span> npm run build</div>
<div class="msb-line msb-sep">─── stage boundary ───</div>
<div class="msb-line"><span class="msb-kw">FROM</span> node:20-alpine</div>
<div class="msb-line"><span class="msb-kw">COPY --from=</span>builder /app/dist ./dist</div>
<div class="msb-line"><span class="msb-kw">COPY --from=</span>builder /app/node_modules ./node_modules</div>
<div class="msb-line"><span class="msb-kw">CMD</span> ["node", "dist/index.js"]</div>`;
---

<div class="msb-wrap">
  <h3 class="msb-title">Multi-Stage Docker Build</h3>
  <div class="msb-compare">
    <div class="msb-stage msb-bad" style="--i:0;">
      <div class="msb-label">Single Stage</div>
      <div class="msb-size">1.2 GB</div>
      <div class="msb-detail">Node.js + npm + dev deps + build tools + source + output</div>
    </div>
    <div class="msb-arrow">→</div>
    <div class="msb-stage msb-good" style="--i:1;">
      <div class="msb-label">Multi-Stage</div>
      <div class="msb-size">180 MB</div>
      <div class="msb-detail">Alpine + production deps + compiled output only</div>
    </div>
  </div>
  <div class="msb-code">
    <Fragment set:html={dockerExample} />
  </div>
</div>

<style>
  .msb-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .msb-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .msb-compare{display:flex;align-items:center;justify-content:center;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap}
  .msb-stage{background:rgba(255,255,255,0.03);border-radius:12px;padding:1.25rem;text-align:center;min-width:200px;opacity:0;animation:msbFade .5s ease forwards;animation-delay:calc(var(--i)*.2s)}
  @keyframes msbFade{from{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}
  .msb-bad{border:1px solid rgba(239,68,68,0.4)}
  .msb-good{border:1px solid rgba(74,222,128,0.4)}
  .msb-label{font-weight:700;font-size:.9rem;margin-bottom:.25rem}
  .msb-bad .msb-label{color:#ef4444}.msb-good .msb-label{color:#4ade80}
  .msb-size{font-size:1.5rem;font-weight:700;margin-bottom:.25rem}
  .msb-bad .msb-size{color:#ef4444}.msb-good .msb-size{color:#4ade80}
  .msb-detail{color:#94a3b8;font-size:.75rem}
  .msb-arrow{color:#64748b;font-size:1.5rem}
  .msb-code{background:rgba(0,0,0,.3);border-radius:10px;padding:1rem;font-family:monospace;font-size:.75rem;line-height:1.8}
  .msb-line{color:#94a3b8}
  .msb-kw{color:#818cf8;font-weight:700}
  .msb-sep{color:#334155;text-align:center;font-size:.65rem}
</style>
