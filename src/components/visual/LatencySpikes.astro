---
// LatencySpikes.astro — Pure CSS animated latency visualization
// Shows how latency compounds across loop iterations in production
---

<div class="ls-wrap">
  <h3 class="ls-title">The Latency Trap — Why Loops Get Slow</h3>
  <p class="ls-sub">Each loop iteration stacks latency. Multiply it by tool calls, and a 200ms API becomes a 14-second experience.</p>

  <div class="ls-layout">
    <!-- The waterfall chart -->
    <div class="ls-waterfall">
      <div class="ls-wf-header">
        <span class="ls-wf-label">Request Waterfall</span>
        <div class="ls-time-axis">
          <span>0s</span><span>2s</span><span>4s</span><span>6s</span><span>8s</span><span>10s</span>
        </div>
      </div>

      <!-- Loop 1 -->
      <div class="ls-group">
        <div class="ls-group-label">Loop 1</div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">LLM plan</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--amber" style="--start:0%;--w:12%;--d:0.2s"></div></div>
          <span class="ls-bar-ms">820ms</span>
        </div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">tool_call</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--cyan" style="--start:12%;--w:4%;--d:0.3s"></div></div>
          <span class="ls-bar-ms">210ms</span>
        </div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">LLM observe</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--amber" style="--start:16%;--w:8%;--d:0.4s"></div></div>
          <span class="ls-bar-ms">540ms</span>
        </div>
      </div>

      <!-- Loop 2 -->
      <div class="ls-group">
        <div class="ls-group-label">Loop 2</div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">LLM refine</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--amber" style="--start:24%;--w:14%;--d:0.5s"></div></div>
          <span class="ls-bar-ms">920ms</span>
        </div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">tool_call_1</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--cyan" style="--start:38%;--w:3%;--d:0.6s"></div></div>
          <span class="ls-bar-ms">190ms</span>
        </div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">tool_call_2</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--cyan" style="--start:38%;--w:6%;--d:0.6s"></div></div>
          <span class="ls-bar-ms">380ms</span>
        </div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">LLM observe</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--amber" style="--start:44%;--w:10%;--d:0.7s"></div></div>
          <span class="ls-bar-ms">650ms</span>
        </div>
      </div>

      <!-- Loop 3 — the problem -->
      <div class="ls-group ls-group--danger">
        <div class="ls-group-label ls-group-label--red">Loop 3 <span class="ls-spike-tag">⚠ SPIKE</span></div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">LLM refine</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--amber" style="--start:54%;--w:18%;--d:0.8s"></div></div>
          <span class="ls-bar-ms">1,200ms</span>
        </div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">tool_call</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--red" style="--start:72%;--w:22%;--d:0.9s"></div></div>
          <span class="ls-bar-ms ls-bar-ms--red">3,100ms ← DB timeout</span>
        </div>
        <div class="ls-bar-row">
          <span class="ls-bar-name">LLM observe</span>
          <div class="ls-bar-track"><div class="ls-bar ls-bar--amber" style="--start:94%;--w:6%;--d:1.0s"></div></div>
          <span class="ls-bar-ms">410ms</span>
        </div>
      </div>
    </div>

    <!-- The math breakdown -->
    <div class="ls-math">
      <div class="ls-math-title">The Compounding Problem</div>
      <div class="ls-formula">
        <div class="ls-formula-row">
          <span class="ls-var">loops</span>
          <span class="ls-op">×</span>
          <span class="ls-var">tools_per_loop</span>
          <span class="ls-op">×</span>
          <span class="ls-var">avg_latency</span>
        </div>
        <div class="ls-formula-result">
          <span class="ls-num">3</span>
          <span class="ls-op">×</span>
          <span class="ls-num">2.3</span>
          <span class="ls-op">×</span>
          <span class="ls-num">620ms</span>
          <span class="ls-op">=</span>
          <span class="ls-num ls-num--red">4.3s baseline</span>
        </div>
        <div class="ls-formula-note">+ one slow tool = <strong>8.4s total</strong></div>
      </div>

      <div class="ls-tips">
        <div class="ls-tip">
          <span class="ls-tip-icon">💡</span>
          <span>Parallelize tool calls within each loop iteration</span>
        </div>
        <div class="ls-tip">
          <span class="ls-tip-icon">💡</span>
          <span>Set per-tool timeouts (not just global)</span>
        </div>
        <div class="ls-tip">
          <span class="ls-tip-icon">💡</span>
          <span>Cache LLM responses for identical sub-questions</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .ls-wrap {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    border-radius: 16px; padding: 2rem; margin: 2rem 0; border: 1px solid #334155;
  }
  .ls-title { color: #f1f5f9; font-size: 1.15rem; font-weight: 700; margin: 0 0 0.25rem; }
  .ls-sub { color: #64748b; font-size: 0.8rem; margin: 0 0 1.5rem; font-family: monospace; }

  .ls-layout {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.5rem;
  }
  @media (max-width: 700px) { .ls-layout { grid-template-columns: 1fr; } }

  /* Waterfall */
  .ls-waterfall {
    background: rgba(0,0,0,0.25); border-radius: 12px; padding: 14px;
    border: 1px solid #334155;
  }
  .ls-wf-header { margin-bottom: 12px; }
  .ls-wf-label { font-family: monospace; font-size: 0.65rem; color: #64748b; display: block; margin-bottom: 4px; }
  .ls-time-axis {
    display: flex; justify-content: space-between;
    font-family: monospace; font-size: 0.5rem; color: #475569;
    border-bottom: 1px solid #334155; padding-bottom: 4px;
  }

  .ls-group { margin-bottom: 12px; }
  .ls-group--danger { background: rgba(239,68,68,0.03); border-radius: 8px; padding: 8px; border: 1px dashed #ef444430; }
  .ls-group-label { font-family: monospace; font-size: 0.6rem; color: #64748b; margin-bottom: 6px; font-weight: 700; }
  .ls-group-label--red { color: #f87171; }
  .ls-spike-tag {
    font-size: 0.5rem; background: rgba(239,68,68,0.15); color: #f87171;
    padding: 1px 5px; border-radius: 3px; margin-left: 4px;
  }

  .ls-bar-row {
    display: grid; grid-template-columns: 65px 1fr 90px; align-items: center; gap: 6px; margin-bottom: 4px;
  }
  .ls-bar-name { font-family: monospace; font-size: 0.55rem; color: #64748b; }
  .ls-bar-track { height: 10px; background: #1e293b; border-radius: 3px; position: relative; overflow: hidden; }
  .ls-bar {
    position: absolute; height: 100%; border-radius: 3px;
    left: var(--start); width: 0;
    animation: ls-grow 0.8s ease-out forwards;
    animation-delay: var(--d);
  }
  .ls-bar--amber { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
  .ls-bar--cyan  { background: linear-gradient(90deg, #06b6d4, #22d3ee); }
  .ls-bar--red   { background: linear-gradient(90deg, #ef4444, #f87171); animation-name: ls-grow-pulse; }
  @keyframes ls-grow { to { width: var(--w); } }
  @keyframes ls-grow-pulse {
    0% { width: 0; }
    70% { width: var(--w); }
    80% { width: calc(var(--w) + 2%); }
    100% { width: var(--w); }
  }

  .ls-bar-ms { font-family: monospace; font-size: 0.55rem; color: #94a3b8; text-align: right; }
  .ls-bar-ms--red { color: #f87171; font-weight: 700; }

  /* Math */
  .ls-math {
    background: rgba(0,0,0,0.25); border-radius: 12px; padding: 14px; border: 1px solid #334155;
  }
  .ls-math-title { font-family: monospace; font-size: 0.7rem; color: #94a3b8; margin-bottom: 12px; font-weight: 700; }

  .ls-formula {
    background: rgba(245,158,11,0.04); border: 1px solid #f59e0b20;
    border-radius: 8px; padding: 12px; margin-bottom: 14px;
  }
  .ls-formula-row { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; flex-wrap: wrap; }
  .ls-var { font-family: monospace; font-size: 0.65rem; color: #fbbf24; background: rgba(245,158,11,0.08); padding: 2px 6px; border-radius: 4px; }
  .ls-op { font-family: monospace; font-size: 0.65rem; color: #475569; }
  .ls-formula-result { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .ls-num { font-family: monospace; font-size: 0.75rem; color: #e2e8f0; font-weight: 700; }
  .ls-num--red { color: #f87171; }
  .ls-formula-note { font-family: monospace; font-size: 0.65rem; color: #94a3b8; margin-top: 8px; }
  .ls-formula-note strong { color: #f87171; }

  .ls-tips { display: flex; flex-direction: column; gap: 6px; }
  .ls-tip {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.7rem; color: #94a3b8; font-family: monospace;
    padding: 6px 10px; border-radius: 6px;
    border: 1px solid #334155; background: rgba(0,0,0,0.15);
  }
  .ls-tip-icon { font-size: 0.8rem; flex-shrink: 0; }
</style>
