---
/**
 * PlatformLayers.astro
 * Internal Developer Platform layers
 */
---

<div class="pl-wrap">
  <h3 class="pl-title">Internal Developer Platform — Layers</h3>
  <div class="pl-stack">
    <div class="pl-layer" style="--i:0; --color:#f59e0b;">
      <div class="pl-name">Developer Portal</div>
      <div class="pl-desc">Service catalog, docs, templates, self-service UI</div>
      <div class="pl-tools">Backstage, Port, Cortex</div>
    </div>
    <div class="pl-layer" style="--i:1; --color:#818cf8;">
      <div class="pl-name">Golden Paths</div>
      <div class="pl-desc">Opinionated templates for new services, CI/CD, IaC</div>
      <div class="pl-tools">Cookiecutter, Yeoman, Scaffolding CLIs</div>
    </div>
    <div class="pl-layer" style="--i:2; --color:#06b6d4;">
      <div class="pl-name">Platform APIs</div>
      <div class="pl-desc">Abstractions over infra: deploy, scale, observe, secure</div>
      <div class="pl-tools">Crossplane, Kratix, custom controllers</div>
    </div>
    <div class="pl-layer" style="--i:3; --color:#4ade80;">
      <div class="pl-name">Infrastructure</div>
      <div class="pl-desc">K8s clusters, databases, queues, networks, secrets</div>
      <div class="pl-tools">Terraform, EKS/GKE, RDS, Kafka</div>
    </div>
  </div>
</div>

<style>
  .pl-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .pl-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .pl-stack{display:flex;flex-direction:column;gap:.75rem}
  .pl-layer{background:rgba(255,255,255,0.03);border:1px solid var(--color);border-radius:12px;padding:1rem 1.25rem;display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;opacity:0;animation:plSlide .5s ease forwards;animation-delay:calc(var(--i)*.15s)}
  @keyframes plSlide{from{opacity:0;transform:translateX(-15px)}to{opacity:1;transform:translateX(0)}}
  .pl-name{color:var(--color);font-weight:700;font-size:.95rem;min-width:150px}
  .pl-desc{color:#94a3b8;font-size:.8rem;flex:1;min-width:200px}
  .pl-tools{color:#64748b;font-size:.7rem;font-family:monospace}
</style>
