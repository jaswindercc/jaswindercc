---
/**
 * WAFVisual.astro
 * Web Application Firewall layers and rules
 */
---

<div class="wfv-wrap">
  <h3 class="wfv-title">WAF Request Processing Pipeline</h3>
  <div class="wfv-pipeline">
    <div class="wfv-stage" style="--i:0;--c:#06b6d4;">
      <div class="wfv-sname">IP Reputation</div>
      <div class="wfv-sdesc">Known-bad IPs, geo-blocking, rate limits</div>
      <div class="wfv-sact">Block / Allow / Rate-limit</div>
    </div>
    <div class="wfv-conn" style="--i:1;">→</div>
    <div class="wfv-stage" style="--i:2;--c:#f59e0b;">
      <div class="wfv-sname">Protocol Validation</div>
      <div class="wfv-sdesc">HTTP compliance, header size, body limits</div>
      <div class="wfv-sact">Drop malformed requests</div>
    </div>
    <div class="wfv-conn" style="--i:3;">→</div>
    <div class="wfv-stage" style="--i:4;--c:#ef4444;">
      <div class="wfv-sname">Rule Matching</div>
      <div class="wfv-sdesc">OWASP CRS, SQLi, XSS, LFI, RCE patterns</div>
      <div class="wfv-sact">Block / Log / Challenge</div>
    </div>
    <div class="wfv-conn" style="--i:5;">→</div>
    <div class="wfv-stage" style="--i:6;--c:#818cf8;">
      <div class="wfv-sname">Bot Detection</div>
      <div class="wfv-sdesc">JS challenge, fingerprinting, CAPTCHA</div>
      <div class="wfv-sact">Challenge suspicious clients</div>
    </div>
    <div class="wfv-conn" style="--i:7;">→</div>
    <div class="wfv-stage" style="--i:8;--c:#4ade80;">
      <div class="wfv-sname">Custom Rules</div>
      <div class="wfv-sdesc">Business logic rules, API schema validation</div>
      <div class="wfv-sact">App-specific enforcement</div>
    </div>
  </div>
</div>

<style>
  .wfv-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .wfv-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .wfv-pipeline{display:flex;align-items:center;gap:.3rem;overflow-x:auto;padding:.5rem 0}
  .wfv-stage{background:rgba(0,0,0,.25);border:1px solid var(--c);border-radius:10px;padding:.8rem;min-width:140px;flex-shrink:0;opacity:0;animation:wfvSlide .3s ease forwards;animation-delay:calc(var(--i)*.1s)}
  .wfv-conn{color:#475569;font-size:1.1rem;flex-shrink:0;opacity:0;animation:wfvSlide .3s ease forwards;animation-delay:calc(var(--i)*.1s)}
  @keyframes wfvSlide{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
  .wfv-sname{color:var(--c);font-weight:700;font-size:.78rem;margin-bottom:.3rem}
  .wfv-sdesc{color:#94a3b8;font-size:.68rem;margin-bottom:.3rem;line-height:1.3}
  .wfv-sact{color:#64748b;font-size:.63rem;font-style:italic;border-top:1px solid rgba(255,255,255,.05);padding-top:.25rem;margin-top:.1rem}
</style>
