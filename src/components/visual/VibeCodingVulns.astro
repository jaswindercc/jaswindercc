---
// VibeCodingVulns.astro — Interactive visualization of AI-generated code vulnerabilities
---

<div class="vc-wrap">
  <h3 class="vc-title">⚠️ Real Vulnerabilities from AI-Generated Code</h3>
  <p class="vc-sub">Each card shows actual insecure patterns Copilot/Cursor produce. Click to reveal the fix.</p>

  <div class="vc-grid">
    <div class="vc-card" tabindex="0">
      <div class="vc-header vc-header--critical">
        <span class="vc-sev">CRITICAL</span>
        <span class="vc-cwe">CWE-89: SQL Injection</span>
      </div>
      <div class="vc-bad">
        <span class="vc-label vc-label--bad">❌ AI Generated</span>
        <pre><code>query = f"SELECT * FROM users WHERE id = {user_id}"
cursor.execute(query)</code></pre>
      </div>
      <div class="vc-good">
        <span class="vc-label vc-label--good">✅ Secure Version</span>
        <pre><code>query = "SELECT * FROM users WHERE id = %s"
cursor.execute(query, (user_id,))</code></pre>
      </div>
    </div>

    <div class="vc-card" tabindex="0">
      <div class="vc-header vc-header--high">
        <span class="vc-sev">HIGH</span>
        <span class="vc-cwe">CWE-22: Path Traversal</span>
      </div>
      <div class="vc-bad">
        <span class="vc-label vc-label--bad">❌ AI Generated</span>
        <pre><code>app.get('/file/:name', (req, res) => {
  res.sendFile(`./uploads/${req.params.name}`);
});</code></pre>
      </div>
      <div class="vc-good">
        <span class="vc-label vc-label--good">✅ Secure Version</span>
        <pre><code>app.get('/file/:name', (req, res) => {
  const safe = path.basename(req.params.name);
  const full = path.resolve('./uploads', safe);
  if (!full.startsWith(path.resolve('./uploads')))
    return res.status(403).send('Blocked');
  res.sendFile(full);
});</code></pre>
      </div>
    </div>

    <div class="vc-card" tabindex="0">
      <div class="vc-header vc-header--high">
        <span class="vc-sev">HIGH</span>
        <span class="vc-cwe">CWE-798: Hardcoded Credentials</span>
      </div>
      <div class="vc-bad">
        <span class="vc-label vc-label--bad">❌ AI Generated</span>
        <pre><code>const db = mysql.connect({
  host: 'prod-db.internal',
  password: 'admin123!'
});</code></pre>
      </div>
      <div class="vc-good">
        <span class="vc-label vc-label--good">✅ Secure Version</span>
        <pre><code>const db = mysql.connect({
  host: process.env.DB_HOST,
  password: await getSecret('db-password')
});</code></pre>
      </div>
    </div>

    <div class="vc-card" tabindex="0">
      <div class="vc-header vc-header--critical">
        <span class="vc-sev">CRITICAL</span>
        <span class="vc-cwe">CWE-352: Missing CSRF</span>
      </div>
      <div class="vc-bad">
        <span class="vc-label vc-label--bad">❌ AI Generated</span>
        <pre><code>app.post('/transfer', (req, res) => {
  transferFunds(req.body.to, req.body.amount);
  res.json({ success: true });
});</code></pre>
      </div>
      <div class="vc-good">
        <span class="vc-label vc-label--good">✅ Secure Version</span>
        <pre><code>app.post('/transfer', csrfProtection, (req, res) => {
  verifyOrigin(req);
  transferFunds(req.body.to, req.body.amount);
  res.json({ success: true });
});</code></pre>
      </div>
    </div>
  </div>
</div>

<style>
  .vc-wrap {
    background: linear-gradient(135deg, #1a0a0a 0%, #0f172a 100%);
    border-radius: 1rem; padding: 2rem; margin: 2rem 0;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
  .vc-title { color: #f1f5f9; font-size: 1.25rem; margin: 0 0 0.25rem; }
  .vc-sub { color: #94a3b8; font-size: 0.875rem; margin: 0 0 1.5rem; }
  .vc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 768px) { .vc-grid { grid-template-columns: 1fr; } }
  .vc-card {
    background: rgba(15, 23, 42, 0.8); border-radius: 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.1); overflow: hidden;
    cursor: pointer; transition: all 0.3s;
  }
  .vc-card:hover, .vc-card:focus { border-color: rgba(148, 163, 184, 0.3); transform: translateY(-2px); }
  .vc-header { padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
  .vc-header--critical { background: rgba(239, 68, 68, 0.15); }
  .vc-header--high { background: rgba(249, 115, 22, 0.15); }
  .vc-sev { font-size: 0.65rem; font-weight: 800; color: #fca5a5; letter-spacing: 0.05em; }
  .vc-cwe { font-size: 0.7rem; color: #94a3b8; }
  .vc-bad { padding: 0.75rem; }
  .vc-good {
    padding: 0.75rem; max-height: 0; overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s;
    background: rgba(16, 185, 129, 0.05);
  }
  .vc-card:hover .vc-good, .vc-card:focus .vc-good { max-height: 300px; padding: 0.75rem; }
  .vc-label { display: block; font-size: 0.7rem; font-weight: 600; margin-bottom: 0.25rem; }
  .vc-label--bad { color: #f87171; }
  .vc-label--good { color: #34d399; }
  .vc-card pre { margin: 0; background: rgba(0,0,0,0.4); border-radius: 0.375rem; padding: 0.5rem; overflow-x: auto; }
  .vc-card code { font-size: 0.7rem; color: #e2e8f0; line-height: 1.5; }
</style>
