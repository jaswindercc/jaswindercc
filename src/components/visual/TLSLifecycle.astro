---
/**
 * TLSLifecycle.astro
 * TLS certificate lifecycle
 */
---

<div class="tls-wrap">
  <h3 class="tls-title">TLS Certificate Lifecycle</h3>
  <div class="tls-steps">
    <div class="tls-step" style="--i:0; --color:#818cf8;">
      <div class="tls-num">1</div>
      <div class="tls-body">
        <div class="tls-name">Generate Key Pair</div>
        <div class="tls-desc">Private key stays on your server. Public key goes in the CSR.</div>
      </div>
    </div>
    <div class="tls-conn"></div>
    <div class="tls-step" style="--i:1; --color:#06b6d4;">
      <div class="tls-num">2</div>
      <div class="tls-body">
        <div class="tls-name">Submit CSR to CA</div>
        <div class="tls-desc">Certificate Signing Request includes your domain and public key.</div>
      </div>
    </div>
    <div class="tls-conn"></div>
    <div class="tls-step" style="--i:2; --color:#f59e0b;">
      <div class="tls-num">3</div>
      <div class="tls-body">
        <div class="tls-name">Validation + Issuance</div>
        <div class="tls-desc">CA verifies domain ownership (DNS, HTTP). Issues signed certificate.</div>
      </div>
    </div>
    <div class="tls-conn"></div>
    <div class="tls-step" style="--i:3; --color:#4ade80;">
      <div class="tls-num">4</div>
      <div class="tls-body">
        <div class="tls-name">Deploy + Monitor</div>
        <div class="tls-desc">Install cert on server/LB. Monitor expiration. Alert at 30 days.</div>
      </div>
    </div>
    <div class="tls-conn"></div>
    <div class="tls-step" style="--i:4; --color:#ef4444;">
      <div class="tls-num">5</div>
      <div class="tls-body">
        <div class="tls-name">Renew Before Expiry</div>
        <div class="tls-desc">Automate with cert-manager or Let's Encrypt ACME. Never renew manually.</div>
      </div>
    </div>
  </div>
</div>

<style>
  .tls-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .tls-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .tls-steps{display:flex;flex-direction:column;gap:0}
  .tls-step{display:flex;align-items:center;gap:1rem;padding:.85rem 1rem;background:rgba(255,255,255,0.03);border:1px solid var(--color);border-radius:12px;opacity:0;animation:tlsSlide .4s ease forwards;animation-delay:calc(var(--i)*.12s)}
  @keyframes tlsSlide{from{opacity:0;transform:translateX(-12px)}to{opacity:1;transform:translateX(0)}}
  .tls-num{width:28px;height:28px;border-radius:50%;background:var(--color);color:#0f172a;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;flex-shrink:0}
  .tls-body{flex:1}
  .tls-name{color:var(--color);font-weight:700;font-size:.9rem}
  .tls-desc{color:#94a3b8;font-size:.78rem;margin-top:.1rem}
  .tls-conn{width:2px;height:10px;background:#334155;margin-left:20px}
</style>
