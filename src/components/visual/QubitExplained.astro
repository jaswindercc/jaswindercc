---
// QubitExplained.astro — Visual explanation of qubits vs classical bits
---

<div class="qex-wrap">
  <h3 class="qex-title">Bit vs Qubit — The Fundamental Difference</h3>
  <p class="qex-sub">A bit is a light switch. A qubit is a spinning coin.</p>

  <div class="qex-grid">
    <div class="qex-side" style="--i:0">
      <div class="qex-badge qex-badge--blue">CLASSICAL BIT</div>
      <div class="qex-visual">
        <div class="qex-switch">
          <div class="qex-state qex-state--on">1</div>
          <div class="qex-or">or</div>
          <div class="qex-state qex-state--off">0</div>
        </div>
      </div>
      <div class="qex-explain">Always one value. Definite. Predictable. Like a light switch — it's on or off. Period.</div>
      <div class="qex-math">States: 2 (per bit)</div>
    </div>
    <div class="qex-side" style="--i:1">
      <div class="qex-badge qex-badge--purple">QUBIT</div>
      <div class="qex-visual">
        <div class="qex-coin">
          <div class="qex-coin-inner">
            <div class="qex-coin-face qex-coin-0">|0⟩</div>
            <div class="qex-coin-face qex-coin-1">|1⟩</div>
            <div class="qex-coin-face qex-coin-s">|ψ⟩</div>
          </div>
        </div>
      </div>
      <div class="qex-explain">Can be 0, 1, or a <em>superposition</em> of both simultaneously — until you measure it.</div>
      <div class="qex-math">States: infinite (on the Bloch sphere)</div>
    </div>
  </div>

  <div class="qex-scale">
    <div class="qex-scale-title">Scaling Power</div>
    <div class="qex-scale-row"><span class="qex-sl">1 bit</span><span class="qex-sv">→ 2 values</span></div>
    <div class="qex-scale-row"><span class="qex-sl">8 bits</span><span class="qex-sv">→ 256 values</span></div>
    <div class="qex-scale-row"><span class="qex-sl qex-sl--q">1 qubit</span><span class="qex-sv qex-sv--q">→ 2 states (superposition)</span></div>
    <div class="qex-scale-row"><span class="qex-sl qex-sl--q">8 qubits</span><span class="qex-sv qex-sv--q">→ 256 states simultaneously</span></div>
    <div class="qex-scale-row qex-scale-row--wow"><span class="qex-sl qex-sl--q">300 qubits</span><span class="qex-sv qex-sv--q">→ more states than atoms in the universe</span></div>
  </div>
</div>

<style>
  .qex-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border-radius:16px;padding:2rem;margin:2rem 0;border:1px solid #334155}
  .qex-title{color:#f1f5f9;font-size:1.15rem;font-weight:700;margin:0 0 .25rem}
  .qex-sub{color:#64748b;font-size:.78rem;margin:0 0 1.5rem;font-family:monospace}
  .qex-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
  @media(max-width:550px){.qex-grid{grid-template-columns:1fr}}
  .qex-side{background:rgba(0,0,0,.2);border:1px solid #334155;border-radius:12px;padding:1.25rem;text-align:center;opacity:0;animation:qexIn .5s ease forwards;animation-delay:calc(var(--i)*.2s)}
  .qex-badge{font-size:.6rem;font-family:monospace;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block;margin-bottom:1rem}
  .qex-badge--blue{color:#38bdf8;background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.2)}
  .qex-badge--purple{color:#a78bfa;background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.2)}
  .qex-visual{height:80px;display:flex;align-items:center;justify-content:center;margin-bottom:.75rem}
  .qex-switch{display:flex;align-items:center;gap:12px}
  .qex-state{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:monospace;font-weight:700;font-size:1.1rem}
  .qex-state--on{background:rgba(56,189,248,.15);color:#38bdf8;border:2px solid #38bdf8}
  .qex-state--off{background:rgba(100,116,139,.1);color:#64748b;border:2px solid #64748b}
  .qex-or{color:#475569;font-size:.65rem;font-family:monospace}
  .qex-coin{perspective:300px;width:60px;height:60px}
  .qex-coin-inner{width:100%;height:100%;position:relative;animation:qexSpin 3s linear infinite}
  .qex-coin-face{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;border-radius:50%;font-family:monospace;font-weight:700;font-size:.9rem}
  .qex-coin-0{background:rgba(167,139,250,.15);color:#a78bfa;border:2px solid #a78bfa;animation:qexPulse 3s ease-in-out infinite}
  .qex-coin-1{display:none}.qex-coin-s{display:none}
  @keyframes qexSpin{0%{transform:rotateY(0)}100%{transform:rotateY(360deg)}}
  @keyframes qexPulse{0%,100%{box-shadow:0 0 10px rgba(167,139,250,.3)}50%{box-shadow:0 0 25px rgba(167,139,250,.6)}}
  .qex-explain{color:#94a3b8;font-size:.72rem;line-height:1.5;margin-bottom:.5rem}
  .qex-math{color:#475569;font-size:.62rem;font-family:monospace}
  .qex-scale{background:rgba(0,0,0,.15);border:1px solid #334155;border-radius:8px;padding:14px}
  .qex-scale-title{color:#f1f5f9;font-size:.75rem;font-weight:600;margin-bottom:8px}
  .qex-scale-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #1e293b}
  .qex-scale-row--wow{border:1px solid rgba(245,158,11,.2);background:rgba(245,158,11,.05);border-radius:6px;padding:6px 8px;margin-top:4px}
  .qex-sl{color:#94a3b8;font-size:.68rem;font-family:monospace}.qex-sl--q{color:#a78bfa}
  .qex-sv{color:#64748b;font-size:.68rem;font-family:monospace}.qex-sv--q{color:#c4b5fd}
  @keyframes qexIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
</style>
