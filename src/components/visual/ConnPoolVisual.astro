---
/**
 * ConnPoolVisual.astro
 * Database connection pooling mechanics
 */
---

<div class="cpv-wrap">
  <h3 class="cpv-title">Connection Pool Lifecycle</h3>
  <div class="cpv-pool">
    <div class="cpv-section" style="--i:0;">
      <div class="cpv-slabel">Application Threads</div>
      <div class="cpv-threads">
        <div class="cpv-thread" style="--t:0;">T1</div>
        <div class="cpv-thread" style="--t:1;">T2</div>
        <div class="cpv-thread" style="--t:2;">T3</div>
        <div class="cpv-thread waiting" style="--t:3;">T4 ⏳</div>
      </div>
    </div>
    <div class="cpv-arrows" style="--i:1;">
      <span>borrow →</span>
      <span>← return</span>
    </div>
    <div class="cpv-section" style="--i:2;">
      <div class="cpv-slabel">Connection Pool</div>
      <div class="cpv-conns">
        <div class="cpv-conn active">C1 (in use)</div>
        <div class="cpv-conn active">C2 (in use)</div>
        <div class="cpv-conn active">C3 (in use)</div>
        <div class="cpv-conn idle">C4 (idle)</div>
        <div class="cpv-conn idle">C5 (idle)</div>
      </div>
    </div>
    <div class="cpv-arrows" style="--i:3;">
      <span>persistent TCP →</span>
    </div>
    <div class="cpv-section" style="--i:4;">
      <div class="cpv-slabel">Database</div>
      <div class="cpv-db">
        <div class="cpv-dbicon">🗄</div>
        <div class="cpv-dbinfo">max_connections: 100</div>
      </div>
    </div>
  </div>
  <div class="cpv-params">
    <div class="cpv-param" style="--pc:#4ade80;">min_idle: 2</div>
    <div class="cpv-param" style="--pc:#06b6d4;">max_size: 10</div>
    <div class="cpv-param" style="--pc:#f59e0b;">timeout: 30s</div>
    <div class="cpv-param" style="--pc:#ef4444;">max_lifetime: 30m</div>
  </div>
</div>

<style>
  .cpv-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .cpv-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .cpv-pool{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;justify-content:center}
  .cpv-section{background:rgba(0,0,0,.2);border-radius:10px;padding:.8rem;opacity:0;animation:cpvFade .4s ease forwards;animation-delay:calc(var(--i)*.12s);min-width:120px}
  @keyframes cpvFade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .cpv-slabel{color:#64748b;font-size:.65rem;text-transform:uppercase;letter-spacing:.05em;text-align:center;margin-bottom:.5rem}
  .cpv-threads{display:flex;flex-direction:column;gap:.25rem}
  .cpv-thread{background:rgba(129,140,248,.15);color:#818cf8;padding:.2rem .5rem;border-radius:4px;font-size:.7rem;font-weight:600;text-align:center}
  .cpv-thread.waiting{background:rgba(239,68,68,.1);color:#ef4444;animation:cpvPulse 1.5s ease infinite}
  @keyframes cpvPulse{0%,100%{opacity:.6}50%{opacity:1}}
  .cpv-arrows{display:flex;flex-direction:column;gap:.2rem;color:#475569;font-size:.6rem;text-align:center;opacity:0;animation:cpvFade .3s ease forwards;animation-delay:calc(var(--i)*.12s)}
  .cpv-conns{display:flex;flex-direction:column;gap:.25rem}
  .cpv-conn{padding:.2rem .5rem;border-radius:4px;font-size:.65rem;text-align:center;font-weight:500}
  .cpv-conn.active{background:rgba(74,222,128,.12);color:#4ade80;border:1px solid rgba(74,222,128,.2)}
  .cpv-conn.idle{background:rgba(100,116,139,.1);color:#94a3b8;border:1px solid rgba(100,116,139,.2)}
  .cpv-db{text-align:center}
  .cpv-dbicon{font-size:1.5rem}
  .cpv-dbinfo{color:#94a3b8;font-size:.65rem;margin-top:.2rem}
  .cpv-params{display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap;margin-top:1rem}
  .cpv-param{background:rgba(0,0,0,.2);border:1px solid var(--pc);color:var(--pc);padding:.25rem .6rem;border-radius:6px;font-size:.68rem;font-family:monospace;font-weight:600}
</style>
