---
/**
 * AgentMemoryTypes.astro
 * Three types of AI agent memory
 */
---

<div class="amt-wrap">
  <h3 class="amt-title">AI Agent Memory Systems</h3>
  <div class="amt-types">
    <div class="amt-type" style="--i:0; --color:#f59e0b;">
      <div class="amt-icon">⚡</div>
      <div class="amt-body">
        <div class="amt-name">Short-Term (Working)</div>
        <div class="amt-scope">Current conversation context</div>
        <div class="amt-how">In-context window. Recent messages, tool results, scratchpad.</div>
        <div class="amt-limit">Limited by model context window (128K-1M tokens)</div>
      </div>
    </div>
    <div class="amt-type" style="--i:1; --color:#818cf8;">
      <div class="amt-icon">📚</div>
      <div class="amt-body">
        <div class="amt-name">Long-Term (Semantic)</div>
        <div class="amt-scope">Persists across conversations</div>
        <div class="amt-how">Vector store of past interactions, user preferences, learned facts.</div>
        <div class="amt-limit">Retrieval quality depends on embedding + search</div>
      </div>
    </div>
    <div class="amt-type" style="--i:2; --color:#4ade80;">
      <div class="amt-icon">🎬</div>
      <div class="amt-body">
        <div class="amt-name">Episodic</div>
        <div class="amt-scope">Specific past experiences</div>
        <div class="amt-how">Stored workflows: "Last time user asked X, I did Y and it worked."</div>
        <div class="amt-limit">Needs structured storage + relevance matching</div>
      </div>
    </div>
  </div>
</div>

<style>
  .amt-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .amt-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .amt-types{display:flex;flex-direction:column;gap:1rem}
  .amt-type{display:flex;gap:1rem;background:rgba(255,255,255,0.03);border:1px solid var(--color);border-radius:12px;padding:1.25rem;opacity:0;animation:amtFade .5s ease forwards;animation-delay:calc(var(--i)*.15s)}
  @keyframes amtFade{from{opacity:0;transform:translateX(-15px)}to{opacity:1;transform:translateX(0)}}
  .amt-icon{font-size:1.5rem;flex-shrink:0}
  .amt-body{flex:1}
  .amt-name{color:var(--color);font-weight:700;font-size:.95rem}
  .amt-scope{color:#f1f5f9;font-size:.8rem;margin:.15rem 0 .4rem}
  .amt-how{color:#94a3b8;font-size:.8rem;margin-bottom:.25rem}
  .amt-limit{color:#64748b;font-size:.75rem;font-style:italic}
</style>
