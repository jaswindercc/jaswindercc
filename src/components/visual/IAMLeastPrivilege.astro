---
/**
 * IAMLeastPrivilege.astro
 * Cloud IAM least privilege visual
 */
---

<div class="iam-wrap">
  <h3 class="iam-title">Cloud IAM — Least Privilege Progression</h3>
  <div class="iam-levels">
    <div class="iam-level" style="--i:0; --color:#ef4444;">
      <div class="iam-badge">Danger</div>
      <div class="iam-policy">AdministratorAccess on all resources</div>
      <div class="iam-risk">One compromised credential = full account takeover</div>
    </div>
    <div class="iam-level" style="--i:1; --color:#f59e0b;">
      <div class="iam-badge">Common</div>
      <div class="iam-policy">PowerUserAccess with broad service permissions</div>
      <div class="iam-risk">Can create/delete most resources. Way too broad.</div>
    </div>
    <div class="iam-level" style="--i:2; --color:#06b6d4;">
      <div class="iam-badge">Better</div>
      <div class="iam-policy">Service-specific managed policies (AmazonS3ReadOnlyAccess)</div>
      <div class="iam-risk">Scoped to one service, but still broad within it</div>
    </div>
    <div class="iam-level" style="--i:3; --color:#4ade80;">
      <div class="iam-badge">Best</div>
      <div class="iam-policy">Custom policy — specific actions on specific resources with conditions</div>
      <div class="iam-risk">Minimum permissions needed. Hard to exploit even if compromised.</div>
    </div>
  </div>
</div>

<style>
  .iam-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .iam-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .iam-levels{display:flex;flex-direction:column;gap:.75rem}
  .iam-level{background:rgba(255,255,255,0.03);border:1px solid var(--color);border-radius:12px;padding:1rem 1.25rem;opacity:0;animation:iamFade .4s ease forwards;animation-delay:calc(var(--i)*.12s)}
  @keyframes iamFade{from{opacity:0;transform:translateX(-12px)}to{opacity:1;transform:translateX(0)}}
  .iam-badge{background:var(--color);color:#0f172a;font-size:.6rem;font-weight:700;padding:.15rem .45rem;border-radius:6px;display:inline-block;margin-bottom:.3rem}
  .iam-policy{color:#f1f5f9;font-size:.85rem;font-weight:600;font-family:monospace;margin-bottom:.2rem}
  .iam-risk{color:#94a3b8;font-size:.78rem}
</style>
