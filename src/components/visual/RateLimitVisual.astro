---
/**
 * RateLimitVisual.astro
 * Rate limiting algorithms compared
 */
---

<div class="rlm-wrap">
  <h3 class="rlm-title">Rate Limiting Algorithms</h3>
  <div class="rlm-algos">
    <div class="rlm-algo" style="--i:0;--c:#06b6d4;">
      <div class="rlm-name">Fixed Window</div>
      <div class="rlm-viz">
        <div class="rlm-window">
          <div class="rlm-block" style="--h:70%"></div>
          <div class="rlm-block" style="--h:100%"></div>
          <div class="rlm-block" style="--h:40%"></div>
        </div>
      </div>
      <div class="rlm-desc">Count requests per fixed time window (e.g., per minute). Simple but allows burst at window boundaries.</div>
      <div class="rlm-verdict">Simple | Boundary burst problem</div>
    </div>
    <div class="rlm-algo" style="--i:1;--c:#f59e0b;">
      <div class="rlm-name">Sliding Window Log</div>
      <div class="rlm-viz">
        <div class="rlm-dots">
          <div class="rlm-dot" style="--d:0"></div>
          <div class="rlm-dot" style="--d:1"></div>
          <div class="rlm-dot" style="--d:2"></div>
          <div class="rlm-dot" style="--d:3"></div>
          <div class="rlm-dot" style="--d:4"></div>
          <div class="rlm-dot fade" style="--d:5"></div>
          <div class="rlm-dot fade" style="--d:6"></div>
        </div>
      </div>
      <div class="rlm-desc">Track timestamp of each request. Count requests in trailing window. Precise but memory-intensive.</div>
      <div class="rlm-verdict">Precise | High memory per user</div>
    </div>
    <div class="rlm-algo" style="--i:2;--c:#4ade80;">
      <div class="rlm-name">Token Bucket</div>
      <div class="rlm-viz">
        <div class="rlm-bucket">
          <div class="rlm-tokens">
            <span class="rlm-tok">●</span><span class="rlm-tok">●</span><span class="rlm-tok">●</span><span class="rlm-tok dim">●</span><span class="rlm-tok dim">●</span>
          </div>
          <div class="rlm-refill">+1 token/sec</div>
        </div>
      </div>
      <div class="rlm-desc">Bucket holds tokens, refilled at fixed rate. Each request consumes a token. Allows controlled bursts.</div>
      <div class="rlm-verdict">Best balance | Industry standard</div>
    </div>
    <div class="rlm-algo" style="--i:3;--c:#818cf8;">
      <div class="rlm-name">Leaky Bucket</div>
      <div class="rlm-viz">
        <div class="rlm-leak">
          <div class="rlm-drop" style="--dd:0">💧</div>
          <div class="rlm-drop" style="--dd:1">💧</div>
          <div class="rlm-drop" style="--dd:2">💧</div>
        </div>
      </div>
      <div class="rlm-desc">Process requests at constant rate regardless of burst. Queue overflow is rejected. Smooths traffic.</div>
      <div class="rlm-verdict">Smooth output | No burst tolerance</div>
    </div>
  </div>
</div>

<style>
  .rlm-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .rlm-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .rlm-algos{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.75rem}
  .rlm-algo{background:rgba(0,0,0,.2);border-radius:12px;padding:1rem;border-top:3px solid var(--c);opacity:0;animation:rlmPop .4s ease forwards;animation-delay:calc(var(--i)*.12s)}
  @keyframes rlmPop{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
  .rlm-name{color:var(--c);font-weight:700;font-size:.85rem;margin-bottom:.5rem;text-align:center}
  .rlm-viz{display:flex;justify-content:center;align-items:center;height:40px;margin-bottom:.5rem}
  .rlm-window{display:flex;gap:3px;align-items:flex-end;height:30px}
  .rlm-block{width:20px;background:#06b6d4;border-radius:2px;height:var(--h);opacity:.7}
  .rlm-dots{display:flex;gap:4px;align-items:center}
  .rlm-dot{width:8px;height:8px;border-radius:50%;background:#f59e0b;animation:rlmPulse 1.5s ease infinite;animation-delay:calc(var(--d)*.15s)}
  .rlm-dot.fade{opacity:.3}
  @keyframes rlmPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.2)}}
  .rlm-bucket{text-align:center}
  .rlm-tokens{display:flex;gap:3px;justify-content:center}
  .rlm-tok{color:#4ade80;font-size:.7rem}.rlm-tok.dim{opacity:.3}
  .rlm-refill{color:#64748b;font-size:.6rem;margin-top:.2rem}
  .rlm-leak{display:flex;gap:6px;justify-content:center}
  .rlm-drop{animation:rlmDrip 1.5s ease infinite;animation-delay:calc(var(--dd)*.3s);font-size:.8rem}
  @keyframes rlmDrip{0%{transform:translateY(-4px)}50%{transform:translateY(4px)}100%{transform:translateY(-4px)}}
  .rlm-desc{color:#94a3b8;font-size:.7rem;line-height:1.4;margin-bottom:.4rem}
  .rlm-verdict{color:#64748b;font-size:.65rem;font-style:italic;border-top:1px solid rgba(255,255,255,.05);padding-top:.3rem}
</style>
