---
/**
 * RAGPipelineAdv.astro
 * Full advanced RAG pipeline with reranking and evaluation
 * Pure CSS, dark theme
 */
---

<div class="ragpl-wrap">
  <h3 class="ragpl-title">Production RAG Pipeline</h3>
  
  <div class="ragpl-pipeline">
    <div class="ragpl-stage" style="--i:0; --color:#818cf8;">
      <div class="ragpl-num">1</div>
      <div class="ragpl-content">
        <div class="ragpl-name">Query Transform</div>
        <div class="ragpl-desc">Rewrite, decompose, or expand the user query for better retrieval</div>
      </div>
    </div>
    <div class="ragpl-conn"></div>
    <div class="ragpl-stage" style="--i:1; --color:#06b6d4;">
      <div class="ragpl-num">2</div>
      <div class="ragpl-content">
        <div class="ragpl-name">Hybrid Search</div>
        <div class="ragpl-desc">Combine vector similarity + BM25 keyword search for recall</div>
      </div>
    </div>
    <div class="ragpl-conn"></div>
    <div class="ragpl-stage" style="--i:2; --color:#f59e0b;">
      <div class="ragpl-num">3</div>
      <div class="ragpl-content">
        <div class="ragpl-name">Rerank</div>
        <div class="ragpl-desc">Cross-encoder scores query-document pairs for precision</div>
      </div>
    </div>
    <div class="ragpl-conn"></div>
    <div class="ragpl-stage" style="--i:3; --color:#4ade80;">
      <div class="ragpl-num">4</div>
      <div class="ragpl-content">
        <div class="ragpl-name">Context Compress</div>
        <div class="ragpl-desc">Extract only relevant passages, strip noise, fit token budget</div>
      </div>
    </div>
    <div class="ragpl-conn"></div>
    <div class="ragpl-stage" style="--i:4; --color:#ef4444;">
      <div class="ragpl-num">5</div>
      <div class="ragpl-content">
        <div class="ragpl-name">Generate + Cite</div>
        <div class="ragpl-desc">LLM generates answer with inline citations to source chunks</div>
      </div>
    </div>
  </div>
</div>

<style>
  .ragpl-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .ragpl-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .ragpl-pipeline{display:flex;flex-direction:column;gap:0}
  .ragpl-stage{display:flex;align-items:center;gap:1rem;padding:1rem;background:rgba(255,255,255,0.03);border:1px solid var(--color);border-radius:12px;opacity:0;animation:ragplSlide .4s ease forwards;animation-delay:calc(var(--i)*.15s)}
  @keyframes ragplSlide{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}
  .ragpl-num{width:32px;height:32px;border-radius:50%;background:var(--color);color:#0f172a;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0}
  .ragpl-content{flex:1}
  .ragpl-name{color:var(--color);font-weight:700;font-size:.95rem}
  .ragpl-desc{color:#94a3b8;font-size:.8rem;margin-top:.15rem}
  .ragpl-conn{width:2px;height:16px;background:#334155;margin-left:24px}
</style>
