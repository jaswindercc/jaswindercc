---
/**
 * SemanticSearchVisual.astro
 * Semantic vs keyword search comparison
 */
---

<div class="ssv-wrap">
  <h3 class="ssv-title">Keyword Search vs Semantic Search</h3>
  <div class="ssv-compare">
    <div class="ssv-side" style="--i:0;--c:#f59e0b;">
      <div class="ssv-sname">Keyword Search</div>
      <div class="ssv-query">Query: "cheap flights to Paris"</div>
      <div class="ssv-how">Matches exact words: cheap, flights, Paris</div>
      <div class="ssv-results">
        <div class="ssv-result match">✓ "Cheap flights to Paris from London"</div>
        <div class="ssv-result match">✓ "Paris flights — cheap deals today"</div>
        <div class="ssv-result miss">✗ "Affordable airfare to France" (no keyword match)</div>
        <div class="ssv-result miss">✗ "Budget travel deals CDG airport" (no match)</div>
      </div>
    </div>
    <div class="ssv-vs">vs</div>
    <div class="ssv-side" style="--i:1;--c:#818cf8;">
      <div class="ssv-sname">Semantic Search</div>
      <div class="ssv-query">Query: "cheap flights to Paris"</div>
      <div class="ssv-how">Matches meaning: affordable air travel → Paris</div>
      <div class="ssv-results">
        <div class="ssv-result match">✓ "Cheap flights to Paris from London"</div>
        <div class="ssv-result match">✓ "Affordable airfare to France"</div>
        <div class="ssv-result match">✓ "Budget travel deals CDG airport"</div>
        <div class="ssv-result match">✓ "Low-cost carriers serving Paris routes"</div>
      </div>
    </div>
  </div>
</div>

<style>
  .ssv-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid #334155;border-radius:16px;padding:2rem;margin:2rem 0}
  .ssv-title{color:#f1f5f9;text-align:center;font-size:1.25rem;margin:0 0 1.5rem}
  .ssv-compare{display:grid;grid-template-columns:1fr auto 1fr;gap:.75rem;align-items:start}
  .ssv-side{background:rgba(0,0,0,.2);border-radius:12px;padding:1rem;border-top:3px solid var(--c);opacity:0;animation:ssvPop .4s ease forwards;animation-delay:calc(var(--i)*.15s)}
  @keyframes ssvPop{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
  .ssv-vs{color:#475569;font-size:1.1rem;font-weight:700;align-self:center;padding-top:2rem}
  .ssv-sname{color:var(--c);font-weight:700;font-size:.9rem;text-align:center;margin-bottom:.5rem}
  .ssv-query{color:#e2e8f0;font-size:.75rem;background:rgba(0,0,0,.2);padding:.3rem .6rem;border-radius:6px;text-align:center;margin-bottom:.4rem;font-family:monospace}
  .ssv-how{color:#64748b;font-size:.68rem;text-align:center;margin-bottom:.6rem;font-style:italic}
  .ssv-results{display:flex;flex-direction:column;gap:.3rem}
  .ssv-result{font-size:.7rem;padding:.25rem .4rem;border-radius:4px}
  .ssv-result.match{color:#4ade80;background:rgba(74,222,128,.06)}
  .ssv-result.miss{color:#ef4444;background:rgba(239,68,68,.06)}
  @media(max-width:600px){.ssv-compare{grid-template-columns:1fr;gap:.5rem}.ssv-vs{text-align:center;padding:0}}
</style>
