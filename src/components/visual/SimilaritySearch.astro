---
// SimilaritySearch.astro — Animated cosine similarity comparison
---

<div class="ss-wrap">
  <h3 class="ss-title">How Similarity Search Works</h3>
  <p class="ss-sub">Your query becomes a vector. The DB finds the closest neighbors. That's it.</p>

  <div class="ss-demo">
    <div class="ss-query-section">
      <div class="ss-section-label">Query</div>
      <div class="ss-query-card">
        <span class="ss-query-text">"How do I reset my password?"</span>
        <span class="ss-query-vec">→ [0.12, -0.08, 0.34, ...]</span>
      </div>
    </div>

    <div class="ss-search-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <div class="ss-search-pulse"></div>
    </div>

    <div class="ss-results-section">
      <div class="ss-section-label">Results (sorted by similarity)</div>
      
      <div class="ss-result ss-result--1">
        <div class="ss-score-bar">
          <div class="ss-score-fill ss-fill--1" style="--w:96%;"></div>
        </div>
        <div class="ss-result-content">
          <span class="ss-score-val ss-sv--green">0.96</span>
          <span class="ss-result-text">"Password reset instructions for all accounts"</span>
          <span class="ss-result-source">help-center/auth.md</span>
        </div>
      </div>

      <div class="ss-result ss-result--2">
        <div class="ss-score-bar">
          <div class="ss-score-fill ss-fill--2" style="--w:89%;"></div>
        </div>
        <div class="ss-result-content">
          <span class="ss-score-val ss-sv--green">0.89</span>
          <span class="ss-result-text">"Forgot password? Here's how to recover access"</span>
          <span class="ss-result-source">faq/account-recovery.md</span>
        </div>
      </div>

      <div class="ss-result ss-result--3">
        <div class="ss-score-bar">
          <div class="ss-score-fill ss-fill--3" style="--w:74%;"></div>
        </div>
        <div class="ss-result-content">
          <span class="ss-score-val ss-sv--amber">0.74</span>
          <span class="ss-result-text">"Account security settings and 2FA setup"</span>
          <span class="ss-result-source">help-center/security.md</span>
        </div>
      </div>

      <div class="ss-result ss-result--4">
        <div class="ss-score-bar">
          <div class="ss-score-fill ss-fill--4" style="--w:31%;"></div>
        </div>
        <div class="ss-result-content">
          <span class="ss-score-val ss-sv--red">0.31</span>
          <span class="ss-result-text">"Billing FAQ and payment methods"</span>
          <span class="ss-result-source">faq/billing.md</span>
        </div>
      </div>

      <div class="ss-threshold">
        <span class="ss-threshold-line"></span>
        <span class="ss-threshold-label">Similarity threshold: 0.70</span>
        <span class="ss-threshold-line"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .ss-wrap {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    border-radius: 16px; padding: 2rem; margin: 2rem 0; border: 1px solid #334155;
  }
  .ss-title { color: #f1f5f9; font-size: 1.15rem; font-weight: 700; margin: 0 0 0.25rem; }
  .ss-sub { color: #64748b; font-size: 0.8rem; margin: 0 0 1.5rem; font-family: monospace; }

  .ss-demo { display: flex; flex-direction: column; gap: 16px; align-items: center; }

  .ss-section-label { color: #94a3b8; font-size: 0.6rem; font-family: monospace; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }

  .ss-query-section { width: 100%; }
  .ss-query-card {
    display: flex; flex-direction: column; gap: 4px; padding: 12px 14px; border-radius: 10px;
    background: rgba(129,140,248,0.06); border: 1px solid #818cf830;
  }
  .ss-query-text { color: #a5b4fc; font-size: 0.8rem; font-weight: 600; }
  .ss-query-vec { color: #475569; font-size: 0.6rem; font-family: monospace; }

  .ss-search-icon { position: relative; width: 36px; height: 36px; }
  .ss-search-icon svg { width: 24px; height: 24px; position: absolute; top: 6px; left: 6px; z-index: 1; }
  .ss-search-pulse {
    position: absolute; top: 0; left: 0; width: 36px; height: 36px; border-radius: 50%;
    background: rgba(6,182,212,0.15); animation: ssPulse 2s ease-out infinite;
  }

  .ss-results-section { width: 100%; }

  .ss-result { margin-bottom: 8px; opacity: 0; animation: ssResultIn 0.5s ease-out forwards; }
  .ss-result--1 { animation-delay: 0.3s; }
  .ss-result--2 { animation-delay: 0.6s; }
  .ss-result--3 { animation-delay: 0.9s; }
  .ss-result--4 { animation-delay: 1.2s; }

  .ss-score-bar { height: 3px; background: rgba(0,0,0,0.2); border-radius: 2px; margin-bottom: 6px; overflow: hidden; }
  .ss-score-fill { height: 100%; border-radius: 2px; width: 0; animation: ssGrow 1s ease-out forwards; }
  .ss-fill--1 { background: #4ade80; animation-delay: 0.5s; }
  .ss-fill--2 { background: #4ade80; animation-delay: 0.8s; }
  .ss-fill--3 { background: #f59e0b; animation-delay: 1.1s; }
  .ss-fill--4 { background: #ef4444; animation-delay: 1.4s; }

  .ss-result-content {
    display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 8px;
    background: rgba(0,0,0,0.2); border: 1px solid #334155;
  }
  .ss-score-val { font-family: monospace; font-size: 0.7rem; font-weight: 800; flex-shrink: 0; }
  .ss-sv--green { color: #4ade80; }
  .ss-sv--amber { color: #f59e0b; }
  .ss-sv--red { color: #ef4444; }
  .ss-result-text { color: #cbd5e1; font-size: 0.72rem; flex: 1; }
  .ss-result-source { color: #475569; font-size: 0.55rem; font-family: monospace; flex-shrink: 0; }

  .ss-threshold {
    display: flex; align-items: center; gap: 8px; margin-top: 4px; opacity: 0;
    animation: ssResultIn 0.5s ease-out 1.5s forwards;
  }
  .ss-threshold-line { flex: 1; height: 1px; background: #f59e0b30; }
  .ss-threshold-label { color: #f59e0b; font-size: 0.55rem; font-family: monospace; white-space: nowrap; }

  @keyframes ssPulse {
    0% { transform: scale(1); opacity: 0.4; }
    100% { transform: scale(2.5); opacity: 0; }
  }
  @keyframes ssResultIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes ssGrow { to { width: var(--w); } }
</style>
