---
// BlochSphere.astro — Simplified Bloch sphere representation of a qubit
---

<div class="bs-wrap">
  <h3 class="bs-title">The Bloch Sphere — Every Qubit State in One Picture</h3>
  <p class="bs-sub">A qubit's state is a point on this sphere. Top = |0⟩. Bottom = |1⟩. Everywhere else = superposition.</p>

  <div class="bs-canvas">
    <svg viewBox="0 0 300 320" class="bs-svg">
      <!-- Sphere outline -->
      <ellipse cx="150" cy="150" rx="110" ry="110" fill="none" stroke="#334155" stroke-width="1" class="bs-sphere"/>
      <ellipse cx="150" cy="150" rx="110" ry="30" fill="none" stroke="#334155" stroke-width="0.5" stroke-dasharray="4,4"/>

      <!-- Axes -->
      <line x1="150" y1="30" x2="150" y2="270" stroke="#475569" stroke-width="0.5" stroke-dasharray="3,3"/>
      <line x1="35" y1="150" x2="265" y2="150" stroke="#475569" stroke-width="0.5" stroke-dasharray="3,3"/>

      <!-- Labels -->
      <text x="150" y="22" fill="#4ade80" font-size="11" text-anchor="middle" font-family="monospace" font-weight="bold" class="bs-label" style="--i:0">|0⟩</text>
      <text x="150" y="288" fill="#ef4444" font-size="11" text-anchor="middle" font-family="monospace" font-weight="bold" class="bs-label" style="--i:1">|1⟩</text>
      <text x="272" y="154" fill="#64748b" font-size="8" font-family="monospace" class="bs-label" style="--i:2">|+⟩</text>
      <text x="20" y="154" fill="#64748b" font-size="8" font-family="monospace" class="bs-label" style="--i:3">|−⟩</text>

      <!-- State vector (animated) -->
      <line x1="150" y1="150" x2="220" y2="75" stroke="#a78bfa" stroke-width="2" class="bs-vector">
        <animateTransform attributeName="transform" type="rotate" values="0 150 150;360 150 150" dur="8s" repeatCount="indefinite"/>
      </line>
      <circle cx="220" cy="75" r="5" fill="#a78bfa" class="bs-state-dot">
        <animateTransform attributeName="transform" type="rotate" values="0 150 150;360 150 150" dur="8s" repeatCount="indefinite"/>
      </circle>

      <!-- Center dot -->
      <circle cx="150" cy="150" r="3" fill="#475569"/>

      <!-- Pole dots -->
      <circle cx="150" cy="40" r="4" fill="#4ade80"/>
      <circle cx="150" cy="260" r="4" fill="#ef4444"/>
    </svg>
  </div>

  <div class="bs-legend">
    <div class="bs-leg-item"><span class="bs-leg-dot" style="background:#4ade80"></span>North pole = |0⟩ (100% zero)</div>
    <div class="bs-leg-item"><span class="bs-leg-dot" style="background:#ef4444"></span>South pole = |1⟩ (100% one)</div>
    <div class="bs-leg-item"><span class="bs-leg-dot" style="background:#a78bfa"></span>Equator = equal superposition (50/50)</div>
    <div class="bs-leg-item"><span class="bs-leg-dot" style="background:#f59e0b"></span>Anywhere else = weighted superposition</div>
  </div>
</div>

<style>
  .bs-wrap{background:linear-gradient(135deg,#0f172a,#1e293b);border-radius:16px;padding:2rem;margin:2rem 0;border:1px solid #334155}
  .bs-title{color:#f1f5f9;font-size:1.15rem;font-weight:700;margin:0 0 .25rem}
  .bs-sub{color:#64748b;font-size:.78rem;margin:0 0 1.5rem;font-family:monospace}
  .bs-canvas{background:rgba(0,0,0,.2);border-radius:12px;border:1px solid #334155;max-width:320px;margin:0 auto 1.5rem}
  .bs-svg{width:100%;height:auto;display:block}
  .bs-label{opacity:0;animation:bsIn .4s ease forwards;animation-delay:calc(var(--i)*.15s)}
  .bs-legend{display:grid;grid-template-columns:1fr 1fr;gap:6px}
  @media(max-width:500px){.bs-legend{grid-template-columns:1fr}}
  .bs-leg-item{display:flex;align-items:center;gap:6px;color:#94a3b8;font-size:.68rem;font-family:monospace}
  .bs-leg-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  @keyframes bsIn{from{opacity:0}to{opacity:1}}
</style>
